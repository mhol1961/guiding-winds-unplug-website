---
interface Image {
  src: string;
  alt: string;
}
interface Props {
  images: Image[];
  fallbackGradient: string;
  emptyTileCount?: number;
}
const { images } = Astro.props;

// 5-tile asymmetric grid - featured 2x2 left, four small tiles right.
// Real photography required; fallback gradient is no longer used since
// every voyage now has galleryImages populated.
const hasImages = images.length > 0;
const tiles = hasImages ? images.slice(0, 5) : [];
---

{hasImages && (
  <section class="bg-bone text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
        <div>
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-4">
            From the field
          </p>
          <h2
            class="font-display font-light leading-[1.05] tracking-[-0.025em]"
            style="font-size: clamp(1.75rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
          >
            What it looks like.
          </h2>
        </div>
        <p class="font-body-md text-[0.9375rem] text-primary/70 max-w-xs">
          A mix of guest photography and licensed imagery while we add to Dodie's library through the 2027 season.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 grid-rows-2 gap-3 lg:gap-4 aspect-[5/4] lg:aspect-[3/2]">
        {
          tiles.map((tile, i) => {
            const isFeatured = i === 0;
            return (
              <figure
                class:list={[
                  'relative overflow-hidden group',
                  isFeatured ? 'col-span-2 row-span-2' : '',
                ]}
              >
                <img
                  src={tile.src}
                  alt={tile.alt}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
                />
              </figure>
            );
          })
        }
      </div>
    </div>
  </section>
)}
