---
import Faq from '../shared/Faq.astro';

interface QA { q: string; a: string }
interface Props {
  faq: QA[];
}
const { faq } = Astro.props;
---

<section class="bg-bone text-primary py-24 sm:py-32 border-t border-rule">
  <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-4">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-5">
          Before you go
        </p>
        <h2
          class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
          style="font-size: clamp(1.875rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
        >
          Questions guests
          <span class="italic block" style="font-variation-settings: 'opsz' 72, 'SOFT' 60, 'WONK' 1;">
            actually ask.
          </span>
        </h2>
        <p class="mt-7 font-body-md text-[1rem] leading-[1.65] text-primary/65">
          The full <a href="/faq" class="text-accent border-b border-accent/40 hover:border-accent transition-colors">23-question FAQ</a> covers everything. If something isn't there, <a href="/inquire" class="text-accent border-b border-accent/40 hover:border-accent transition-colors">just ask</a>.
        </p>
      </div>

      <div class="lg:col-span-8">
        <Faq items={faq} />
      </div>
    </div>
  </div>
</section>
