---
interface Day {
  day: number;
  label: string;
  title: string;
  body: string;
}

interface Props {
  itinerary: Day[];
}
const { itinerary } = Astro.props;
---

<section class="bg-bone text-primary py-24 sm:py-32 border-t border-rule">
  <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 mb-16">
      <div class="lg:col-span-5">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-5">
          The week, day by day
        </p>
        <h2
          class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
          style="font-size: clamp(1.875rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
        >
          A sample itinerary.
          <span class="italic block" style="font-variation-settings: 'opsz' 72, 'SOFT' 60, 'WONK' 1;">
            Weather and mood get a vote.
          </span>
        </h2>
      </div>
    </div>

    <ol class="relative max-w-3xl mx-auto lg:mx-0">
      {/* Vertical sun-gold rail */}
      <div class="absolute left-[11px] top-2 bottom-2 w-px bg-rule" aria-hidden="true"></div>

      {
        itinerary.map((day) => (
          <li class="relative pl-12 pb-12 last:pb-0">
            <span
              class="absolute left-0 top-[5px] inline-flex items-center justify-center size-6 rounded-full bg-bone border border-rule"
              aria-hidden="true"
            >
              <span class="size-[7px] rounded-full bg-sun" />
            </span>
            <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-primary/55 mb-2">
              Day {day.day} · {day.label}
            </p>
            <h3
              class="font-display text-[1.625rem] leading-[1.15] tracking-[-0.015em] font-normal mb-3"
              style="font-variation-settings: 'opsz' 36, 'SOFT' 30, 'WONK' 0;"
            >
              {day.title}
            </h3>
            <p class="font-body-md text-[1rem] leading-[1.7] text-primary/75 max-w-prose">
              {day.body}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
