---
import { Check } from 'lucide-react';

interface AvailableWeek {
  start: string;
  end: string;
  cabinsAvailable: number;
}

interface Props {
  pricePerGuestUSD: number;
  availableWeeks: AvailableWeek[];
  voyageName: string;
  voyageSlug: string;
}

const { pricePerGuestUSD, availableWeeks, voyageSlug } = Astro.props;

function formatWeek(start: string, end: string): string {
  const s = new Date(`${start}T12:00:00Z`);
  const e = new Date(`${end}T12:00:00Z`);
  const fmt = (d: Date) =>
    d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
  const year = s.getUTCFullYear();
  return `${fmt(s)} – ${fmt(e)}, ${year}`;
}
---

<aside class="bg-bone border border-rule p-7 lg:p-8 lg:sticky lg:top-28">
  <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-primary/70 mb-4">
    All-inclusive · From
  </p>
  <div class="flex items-baseline gap-2 mb-1">
    <span class="font-display text-[3.25rem] leading-none text-primary tabular-nums" style="font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;">
      ${pricePerGuestUSD.toLocaleString()}
    </span>
    <span class="font-body-md text-[1rem] text-primary/65">/ guest</span>
  </div>
  <p class="font-body-sm text-[0.875rem] text-primary/70 mb-7">
    Meals, premium bar, gear, fuel, dockage. No hidden fees.
  </p>

  <div class="space-y-2.5 mb-7">
    {
      ['Chef-prepared meals, twice daily', 'Premium open bar', 'Snorkel + paddleboards + kayaks', 'Private cabin with ensuite head'].map(
        (item) => (
          <div class="flex items-start gap-2.5">
            <Check className="size-4 text-sun shrink-0 mt-[3px]" strokeWidth={2} />
            <span class="font-body-md text-[0.9375rem] text-primary/80">{item}</span>
          </div>
        ),
      )
    }
  </div>

  <div class="border-t border-rule pt-6 mb-6">
    <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-primary/70 mb-4">
      2027 weeks · {availableWeeks.length} available
    </p>
    <ul class="space-y-3">
      {
        availableWeeks.map((week) => (
          <li class="flex items-center justify-between gap-4">
            <span class="font-body-md text-[0.9375rem] text-primary tabular-nums">
              {formatWeek(week.start, week.end)}
            </span>
            <span
              class:list={[
                'font-label-caps uppercase tracking-[0.2em] text-[0.5625rem] font-semibold tabular-nums whitespace-nowrap',
                week.cabinsAvailable === 0
                  ? 'text-primary/40'
                  : week.cabinsAvailable <= 2
                    ? 'text-accent'
                    : 'text-primary/70',
              ]}
            >
              {week.cabinsAvailable === 0 ? 'Sold out' : `${week.cabinsAvailable} cabins`}
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <a
    href={`/inquire?voyage=${voyageSlug}`}
    class="block w-full text-center cursor-pointer bg-primary text-bone font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-6 py-[18px] hover:bg-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
  >
    Hold a Cabin
  </a>
  <p class="font-body-sm text-[0.75rem] text-primary/70 mt-4 leading-relaxed text-center">
    72-hour soft hold. No deposit required. Reply when you decide.
  </p>
</aside>
