---
// Shared 3-step lead questionnaire for the ad landing pages.
// Posts to /api/inquire via the global form-handlers (which, on success,
// sets the gw_inquiry_lead flag → fires the Meta Pixel Lead on /inquire/thank-you).
// `source` attributes the lead to the specific LP variant in GHL.
interface Props {
  source: string; // 'lp-1' | 'lp-2' | 'lp-3'
  heading?: string;
  sub?: string;
}
const {
  source,
  heading = 'Find your week aboard',
  sub = 'Three quick questions. Dodie or Clint replies within 24 hours — no call center, no hard sell.',
} = Astro.props;

const inputCls =
  'w-full bg-white text-primary font-body-md text-[1rem] border-b border-primary/25 focus:border-accent transition-colors px-1 py-3 focus:outline-none';
const labelCls =
  'block font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary/70 mb-2';
const regions = [
  { value: 'bvi', label: 'British Virgin Islands', note: 'Turquoise water, the Baths, Anegada' },
  { value: 'bahamas', label: 'The Bahamas', note: 'Pink sand, the slow Caribbean' },
  { value: 'mediterranean', label: 'The Mediterranean', note: 'Greece · Italy · Croatia' },
];
---

<section id="start" class="bg-bone text-primary scroll-mt-6">
  <div class="mx-auto max-w-2xl px-6 py-16 lg:py-24">
    <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-accent mb-4">
      Hold a cabin
    </p>
    <h2
      class="font-display font-light leading-[1.02] tracking-[-0.025em]"
      style="font-size: clamp(1.9rem, 4vw + 1rem, 3rem);"
    >
      {heading}
    </h2>
    <p class="font-body-lg text-[1.0625rem] leading-[1.6] text-primary/70 mt-4">{sub}</p>

    <form
      method="POST"
      action="/api/inquire"
      data-inquiry-form
      data-lp-quiz
      class="mt-10 relative"
    >
      <input type="hidden" name="source" value={source} />
      {/* Honeypot — must stay empty; bots fill it and get silently dropped */}
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="absolute -left-[9999px] h-0 w-0 opacity-0"
        aria-hidden="true"
      />

      <!-- progress -->
      <div class="mb-8">
        <div class="flex items-center justify-between mb-2">
          <span data-progress class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary/55">Step 1 of 3</span>
        </div>
        <div class="h-[3px] bg-primary/10">
          <div data-progress-bar class="h-full bg-accent transition-[width] duration-300" style="width:33%"></div>
        </div>
      </div>

      <!-- STEP 1 — where + who -->
      <div data-step>
        <fieldset>
          <legend class={labelCls}>Which waters? <span class="text-accent">*</span></legend>
          <div class="grid gap-3 mt-1">
            {regions.map((r) => (
              <label class="group flex items-start gap-3 border border-primary/20 hover:border-accent has-[:checked]:border-accent has-[:checked]:bg-accent/[0.04] transition-colors cursor-pointer px-4 py-3.5">
                <input type="radio" name="region" value={r.value} required class="mt-1 accent-accent size-4 shrink-0" />
                <span>
                  <span class="block font-body-md text-[1rem] text-primary font-medium">{r.label}</span>
                  <span class="block font-body-sm text-[0.8125rem] text-primary/55">{r.note}</span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>

        <div class="mt-7">
          <label class={labelCls} for={`party-${source}`}>How many in your party? <span class="text-accent">*</span></label>
          <select id={`party-${source}`} name="partySize" required class={inputCls}>
            <option value="" disabled selected>Choose a size</option>
            <option>Just me</option>
            <option>2 (couple)</option>
            <option>3–4</option>
            <option>5–6</option>
            <option>7–8</option>
            <option>9–12</option>
            <option>Whole boat / not sure yet</option>
          </select>
        </div>

        <button type="button" data-next class="mt-9 w-full inline-flex items-center justify-center gap-2 cursor-pointer bg-accent text-primary font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-accent-hot transition-colors">
          Continue <span aria-hidden="true">→</span>
        </button>
      </div>

      <!-- STEP 2 — when -->
      <div data-step hidden>
        <label class={labelCls} for={`week-${source}`}>When would you like to sail?</label>
        <input id={`week-${source}`} name="week" type="text" maxlength="120" placeholder="A month, a season, or specific dates" class={inputCls} />

        <div class="mt-7">
          <label class={labelCls} for={`notes-${source}`}>Anything we should know? (optional)</label>
          <textarea id={`notes-${source}`} name="notes" rows="3" maxlength="2000" placeholder="Occasion, dietary needs, questions…" class={`${inputCls} resize-none`}></textarea>
        </div>

        <div class="mt-9 flex items-center gap-3">
          <button type="button" data-back class="cursor-pointer text-primary/60 hover:text-primary font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold px-4 py-[18px] transition-colors">← Back</button>
          <button type="button" data-next class="flex-1 inline-flex items-center justify-center gap-2 cursor-pointer bg-accent text-primary font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-accent-hot transition-colors">
            Continue <span aria-hidden="true">→</span>
          </button>
        </div>
      </div>

      <!-- STEP 3 — who you are -->
      <div data-step hidden>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label class={labelCls} for={`first-${source}`}>First name <span class="text-accent">*</span></label>
            <input id={`first-${source}`} name="firstName" required autocomplete="given-name" maxlength="60" class={inputCls} />
          </div>
          <div>
            <label class={labelCls} for={`last-${source}`}>Last name <span class="text-accent">*</span></label>
            <input id={`last-${source}`} name="lastName" required autocomplete="family-name" maxlength="60" class={inputCls} />
          </div>
        </div>
        <div class="mt-6">
          <label class={labelCls} for={`email-${source}`}>Email <span class="text-accent">*</span></label>
          <input id={`email-${source}`} name="email" type="email" required autocomplete="email" maxlength="254" class={inputCls} />
        </div>
        <div class="mt-6">
          <label class={labelCls} for={`phone-${source}`}>Phone (optional)</label>
          <input id={`phone-${source}`} name="phone" type="tel" autocomplete="tel" maxlength="40" class={inputCls} />
        </div>

        <div class="mt-9 flex items-center gap-3">
          <button type="button" data-back class="cursor-pointer text-primary/60 hover:text-primary font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold px-4 py-[18px] transition-colors">← Back</button>
          <button type="submit" class="flex-1 inline-flex items-center justify-center gap-2 cursor-pointer bg-accent text-primary font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-accent-hot transition-colors">
            Send my request
          </button>
        </div>
        <p class="mt-4 font-body-sm text-[0.75rem] text-primary/50 text-center">
          No spam, no call center. A reply from Dodie or Clint within 24 hours.
        </p>
      </div>

      <!-- inline status (used by form-handlers on error) -->
      <div data-inquiry-status role="status" aria-live="polite" class="mt-5 font-body-sm text-[0.875rem]"></div>
    </form>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLFormElement>('[data-lp-quiz]');
  if (root) {
    const steps = Array.from(root.querySelectorAll<HTMLElement>('[data-step]'));
    const progress = root.querySelector<HTMLElement>('[data-progress]');
    const bar = root.querySelector<HTMLElement>('[data-progress-bar]');
    let i = 0;

    const show = (n: number) => {
      i = Math.max(0, Math.min(n, steps.length - 1));
      steps.forEach((s, idx) => (s.hidden = idx !== i));
      if (progress) progress.textContent = `Step ${i + 1} of ${steps.length}`;
      if (bar) bar.style.width = `${((i + 1) / steps.length) * 100}%`;
      const focusable = steps[i].querySelector<HTMLElement>('input, select, textarea, button');
      focusable?.focus({ preventScroll: true });
    };

    const validStep = (): boolean => {
      const fields = steps[i].querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>(
        'input, select, textarea',
      );
      for (const f of fields) {
        if (!f.checkValidity()) {
          f.reportValidity();
          return false;
        }
      }
      return true;
    };

    root.querySelectorAll<HTMLButtonElement>('[data-next]').forEach((btn) =>
      btn.addEventListener('click', () => {
        if (validStep()) show(i + 1);
      }),
    );
    root.querySelectorAll<HTMLButtonElement>('[data-back]').forEach((btn) =>
      btn.addEventListener('click', () => show(i - 1)),
    );

    show(0);
  }
</script>
