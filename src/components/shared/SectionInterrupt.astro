---
// Site-wide mid-page pattern interrupt. Breaks long stretches of bone
// (#F4EFE0) with a distinct surface — used across home, about, aboard,
// voyages-hub, journal-hub, and voyage detail pages where extended
// cream runs flatlined the eye. Four variants by mood and weight:
//
//   photo  — FULL-BLEED hero-style image with overlay headline. Image
//            IS the section. Highest visual impact, heaviest payload
//            (lazy-loaded). Use as the strongest break — once per page max.
//   quote  — full-bleed photo + italic guest quote + optional CTA.
//            Models LogbookQuote.astro. Use for emotional proof.
//   stat   — dark surface (surface-warm), big-type single statistic +
//            sun-gold rule. No image. Use for credibility / scarcity.
//   teal   — bright teal panel (#0E3F47), italic eyebrow phrase.
//            No image. Lightest break — use freely between bone sections.

interface Props {
  variant: 'photo' | 'quote' | 'stat' | 'teal';
  eyebrow?: string;
  /** Display headline; can be split into a leading phrase + italic emphasis. */
  headline: string;
  /** Italicized phrase appended after `headline` (≤3 words). */
  headlineItalic?: string;
  /** Body paragraph beneath the headline. */
  body?: string;
  ctaLabel?: string;
  ctaHref?: string;
  /** Used by `quote` and `photo` variants. Required for `photo`. */
  image?: string;
  imageAlt?: string;
  /** Attribution shown under the quote (e.g., "Emily R. · Portland, OR"). */
  attribution?: string;
  /** Photo variant text alignment. Default 'left' (editorial). */
  photoAlign?: 'left' | 'center';
}

const {
  variant,
  eyebrow,
  headline,
  headlineItalic,
  body,
  ctaLabel,
  ctaHref,
  image,
  imageAlt,
  attribution,
  photoAlign = 'left',
} = Astro.props;
---

{
  variant === 'photo' && image && (
    <section class="relative bg-primary text-ink overflow-hidden border-t border-hairline min-h-[70dvh] lg:min-h-[78dvh] flex">
      <img
        src={image}
        alt={imageAlt ?? ''}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 w-full h-full object-cover"
      />
      {/* Two-layer overlay: vertical (top→bottom) + horizontal rake from the chosen side */}
      <div
        class="absolute inset-0 bg-gradient-to-b from-primary/45 via-primary/15 to-primary/85"
        aria-hidden="true"
      />
      <div
        class:list={[
          'absolute inset-0',
          photoAlign === 'center'
            ? 'bg-gradient-to-b from-primary/20 via-primary/10 to-primary/55'
            : 'bg-gradient-to-r from-primary/70 via-primary/30 to-transparent',
        ]}
        aria-hidden="true"
      />
      <div
        class:list={[
          'relative max-w-[1400px] w-full mx-auto px-7 lg:px-14 py-28 lg:py-36 flex flex-col justify-end',
          photoAlign === 'center' && 'items-center text-center',
        ]}
      >
        <div class:list={['w-full', photoAlign === 'center' ? 'max-w-3xl' : 'max-w-3xl']}>
          {eyebrow && (
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-sun mb-7">
              {eyebrow}
            </p>
          )}
          <h2
            class="font-display font-light text-ink leading-[0.98] tracking-[-0.025em] text-balance"
            style="font-size: clamp(2.25rem, 5vw + 1rem, 4.25rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
          >
            {headline}
            {headlineItalic && (
              <span
                class="italic block mt-2"
                style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;"
              >
                {headlineItalic}
              </span>
            )}
          </h2>
          {body && (
            <p
              class:list={[
                'mt-7 font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.65] text-ink/85 text-balance',
                photoAlign === 'center' ? 'mx-auto max-w-xl' : 'max-w-xl',
              ]}
            >
              {body}
            </p>
          )}
          {ctaLabel && ctaHref && (
            <div class="mt-9">
              <a
                href={ctaHref}
                class="group inline-flex items-center justify-center gap-3 cursor-pointer bg-bone text-primary font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-9 py-[18px] hover:bg-sun transition-colors focus-visible:outline-2 focus-visible:outline-sun focus-visible:outline-offset-3"
              >
                {ctaLabel}
                <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>
          )}
        </div>
      </div>
    </section>
  )
}

{
  variant === 'quote' && (
    <section class="relative bg-primary text-ink overflow-hidden border-t border-hairline">
      {image && (
        <img
          src={image}
          alt={imageAlt ?? ''}
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover object-center opacity-70"
        />
      )}
      <div
        class="absolute inset-0 bg-gradient-to-r from-primary/85 via-primary/55 to-primary/25"
        aria-hidden="true"
      />
      <div class="relative max-w-[1400px] mx-auto px-7 lg:px-14 py-28 lg:py-36 min-h-[52dvh] flex flex-col justify-center">
        <div class="max-w-2xl">
          {eyebrow && (
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-sun mb-8">
              {eyebrow}
            </p>
          )}
          <blockquote
            class="font-serif-quote italic text-ink leading-[1.3] tracking-[-0.015em] text-balance"
            style="font-size: clamp(1.5rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 60, 'WONK' 1;"
          >
            <span
              class="text-sun text-[3rem] leading-none -ml-2 mr-1 align-middle"
              aria-hidden="true"
              style="font-variation-settings: 'opsz' 144;"
            >
              &ldquo;
            </span>
            {headline}
            {headlineItalic && <span>{headlineItalic}</span>}
          </blockquote>
          {attribution && (
            <p class="mt-8 font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-ink/85">
              {attribution}
            </p>
          )}
          {ctaLabel && ctaHref && (
            <div class="mt-10">
              <a
                href={ctaHref}
                class="group inline-flex items-center gap-3 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold text-ink border-b-2 border-sun pb-1 hover:text-sun transition-colors"
              >
                {ctaLabel}
                <svg
                  viewBox="0 0 16 16"
                  class="size-3 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>
          )}
        </div>
      </div>
    </section>
  )
}

{
  variant === 'stat' && (
    <section class="relative bg-surface-warm text-ink overflow-hidden border-t border-hairline">
      <div class="relative max-w-[1400px] mx-auto px-7 lg:px-14 py-24 sm:py-28">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          <div class="lg:col-span-5">
            <div class="border-l-2 border-sun pl-8">
              {eyebrow && (
                <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-sun mb-6">
                  {eyebrow}
                </p>
              )}
              <p
                class="font-display text-ink leading-[1.0] tabular-nums"
                style="font-size: clamp(2.5rem, 5vw + 1rem, 4rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
              >
                {headline}
                {headlineItalic && (
                  <span
                    class="italic block text-sun mt-1"
                    style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;"
                  >
                    {headlineItalic}
                  </span>
                )}
              </p>
            </div>
          </div>
          <div class="lg:col-span-7">
            {body && (
              <p class="font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.7] text-ink/80 max-w-xl">
                {body}
              </p>
            )}
            {ctaLabel && ctaHref && (
              <div class="mt-9">
                <a
                  href={ctaHref}
                  class="group inline-flex items-center justify-center gap-3 cursor-pointer bg-bone text-primary font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-9 py-[18px] hover:bg-sun transition-colors focus-visible:outline-2 focus-visible:outline-sun focus-visible:outline-offset-3"
                >
                  {ctaLabel}
                  <svg
                    viewBox="0 0 16 16"
                    class="size-3 group-hover:translate-x-1 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  )
}

{
  variant === 'teal' && (
    <section class="relative bg-teal-shadow text-ink overflow-hidden border-t border-hairline">
      <div class="relative max-w-[1400px] mx-auto px-7 lg:px-14 py-20 sm:py-24">
        <div class="max-w-3xl">
          {eyebrow && (
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-sun mb-7">
              {eyebrow}
            </p>
          )}
          <p
            class="font-display font-light text-ink leading-[1.15] tracking-[-0.02em] text-balance"
            style="font-size: clamp(1.625rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
          >
            {headline}
            {headlineItalic && (
              <span
                class="italic text-sun"
                style="font-variation-settings: 'opsz' 72, 'SOFT' 60, 'WONK' 1;"
              >
                {' '}
                {headlineItalic}
              </span>
            )}
          </p>
          {body && (
            <p class="mt-6 font-body-md text-[1rem] lg:text-[1.0625rem] leading-[1.65] text-ink/75 max-w-2xl">
              {body}
            </p>
          )}
          {ctaLabel && ctaHref && (
            <div class="mt-8">
              <a
                href={ctaHref}
                class="group inline-flex items-center gap-3 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold text-ink border-b border-sun/80 pb-1 hover:text-sun transition-colors"
              >
                {ctaLabel}
                <svg
                  viewBox="0 0 16 16"
                  class="size-3 group-hover:translate-x-1 transition-transform"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </a>
            </div>
          )}
        </div>
      </div>
    </section>
  )
}
