---
const links = [
  { label: 'Voyages', href: '/voyages' },
  { label: 'Aboard', href: '/aboard' },
  { label: 'Our Story', href: '/about' },
  { label: 'Journal', href: '/journal' },
];
const ctaLabel = 'Hold a Cabin';
const ctaHref = '/calendar';

interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
---

<header
  data-transparent={transparent}
  class:list={[
    'fixed top-0 inset-x-0 z-30 transition-all duration-300',
    transparent
      ? 'bg-transparent'
      : 'bg-primary/95 backdrop-blur-md border-b border-hairline',
  ]}
>
  <div class="max-w-[1320px] mx-auto px-7 lg:px-14 h-20 flex items-center justify-between gap-8">
    <a
      href="/"
      class="font-display text-[1.375rem] leading-none tracking-[-0.02em] text-ink hover:text-accent transition-colors"
      style="font-variation-settings: 'opsz' 60, 'SOFT' 30, 'WONK' 0;"
      aria-label="Guiding Winds Unplug — home"
    >
      Guiding Winds
    </a>

    <nav class="hidden md:flex items-center gap-10" aria-label="Primary">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft hover:text-ink transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={ctaHref}
        class="hidden md:inline-flex items-center justify-center cursor-pointer bg-accent text-ink font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-6 py-3 hover:bg-accent-hot transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
      >
        {ctaLabel}
      </a>

      {/* Mobile menu trigger — native <dialog>, no React. */}
      <button
        type="button"
        aria-label="Open menu"
        aria-controls="mobile-menu-dialog"
        data-mobile-menu-trigger
        class="md:hidden inline-flex items-center justify-center size-11 cursor-pointer text-ink hover:text-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
      >
        <svg viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

{/* Mobile menu dialog. Native <dialog> = no React, no Radix, ~0KB JS cost. */}
<dialog
  id="mobile-menu-dialog"
  class="bg-primary text-ink p-0 m-0 max-w-none w-full h-full md:hidden backdrop:bg-primary/70 backdrop:backdrop-blur-md"
  aria-label="Menu"
>
  <div class="p-8 sm:p-12 h-full flex flex-col">
    <div class="flex items-center justify-between mb-10">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft">
        Menu
      </p>
      <button
        type="button"
        aria-label="Close menu"
        data-mobile-menu-close
        class="inline-flex items-center justify-center size-11 cursor-pointer text-ink-soft hover:text-ink transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
      >
        <svg viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
    <nav class="flex flex-col gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            data-mobile-menu-link
            class="font-h3 text-[1.5rem] leading-[1.1] tracking-[-0.015em] text-ink hover:text-accent transition-colors"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <div class="mt-auto pt-10">
      <a
        href={ctaHref}
        data-mobile-menu-link
        class="block w-full text-center cursor-pointer bg-accent text-ink font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-6 py-[18px] hover:bg-accent-hot transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</dialog>

<script>
  // Native dialog wiring. ~300 bytes vs. 32KB of Radix Dialog.
  const trigger = document.querySelector<HTMLButtonElement>('[data-mobile-menu-trigger]');
  const dialog = document.getElementById('mobile-menu-dialog') as HTMLDialogElement | null;
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-mobile-menu-close]');
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-mobile-menu-link]');

  if (trigger && dialog) {
    trigger.addEventListener('click', () => dialog.showModal());
  }
  if (closeBtn && dialog) {
    closeBtn.addEventListener('click', () => dialog.close());
  }
  links.forEach((link) => link.addEventListener('click', () => dialog?.close()));

  // Click outside to close.
  if (dialog) {
    dialog.addEventListener('click', (event) => {
      const rect = dialog.getBoundingClientRect();
      const clicked = event.target as HTMLElement;
      // Backdrop click — close. Inner click — keep open.
      if (clicked === dialog) dialog.close();
    });
  }

  // Transparent → solid header on scroll.
  const header = document.querySelector('header[data-transparent="true"]');
  if (header) {
    const apply = () => {
      if (window.scrollY > 24) {
        header.classList.remove('bg-transparent');
        header.classList.add('bg-primary/95', 'backdrop-blur-md', 'border-b', 'border-hairline');
      } else {
        header.classList.add('bg-transparent');
        header.classList.remove('bg-primary/95', 'backdrop-blur-md', 'border-b', 'border-hairline');
      }
    };
    apply();
    window.addEventListener('scroll', apply, { passive: true });
  }
</script>
