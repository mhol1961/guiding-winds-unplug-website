---
// Native <details>/<summary> accordion. Zero JS. Tuned for bone-bg
// context - dark text, rule dividers, sun-gold icon.
interface QA { q: string; a: string }
interface Props {
  items: QA[];
}
const { items } = Astro.props;
---

<div class="w-full">
  {
    items.map((item, i) => (
      <details
        class="group border-b border-rule"
        data-faq-item={i}
      >
        <summary class="flex w-full items-center justify-between gap-6 py-7 cursor-pointer list-none text-left font-display text-[1.125rem] sm:text-[1.25rem] leading-[1.25] tracking-[-0.015em] font-normal text-primary transition-colors hover:text-accent focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2" style="font-variation-settings: 'opsz' 36;">
          <span class="flex-1">{item.q}</span>
          <span
            aria-hidden="true"
            class="shrink-0 inline-flex items-center justify-center size-5 text-sun transition-transform duration-300 group-open:rotate-45"
          >
            <svg viewBox="0 0 20 20" class="size-5" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 4v12M4 10h12" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </summary>
        <div class="pb-7 pr-12 font-body-md text-[1rem] leading-[1.7] text-primary/75">
          {item.a}
        </div>
      </details>
    ))
  }
</div>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { display: none; content: ''; }
</style>
