---
// Two variants:
// 'footer' — on dark primary bg, ink type with sun-gold accent
// 'inline' — on bone bg with dark type (for embedding in editorial pages)
interface Props {
  variant?: 'inline' | 'footer';
  heading?: string;
  subtext?: string;
}
const {
  variant = 'footer',
  heading = 'Field Notes — a quiet newsletter',
  subtext = 'One or two pieces a month from the water. No urgency, no upsells.',
} = Astro.props;

const isInline = variant === 'inline';
---

<form
  method="POST"
  action="/api/newsletter"
  class:list={[
    'w-full relative',
    isInline ? 'bg-bone text-primary p-10 sm:p-12' : 'text-ink',
  ]}
  data-newsletter
>
  <p
    class:list={[
      'font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold mb-4',
      isInline ? 'text-primary/55' : 'text-ink-soft',
    ]}
  >
    Newsletter
  </p>
  <h3
    class:list={[
      'font-display text-[1.5rem] lg:text-[1.75rem] leading-[1.15] tracking-[-0.02em] mb-3',
      isInline ? 'text-primary' : 'text-ink',
    ]}
    style="font-variation-settings: 'opsz' 36, 'SOFT' 30, 'WONK' 0;"
  >
    {heading}
  </h3>
  <p
    class:list={[
      'font-body-md text-[0.9375rem] leading-[1.65] mb-6',
      isInline ? 'text-primary/70' : 'text-ink/70',
    ]}
  >
    {subtext}
  </p>

  <div class="flex flex-col sm:flex-row gap-2">
    <label class="sr-only" for={`nl-email-${variant}`}>Email address</label>
    <input
      id={`nl-email-${variant}`}
      type="email"
      name="email"
      required
      autocomplete="email"
      placeholder="your.email@example.com"
      class:list={[
        'flex-1 px-4 py-3.5 font-body-md text-[0.9375rem] border-b transition-colors focus-visible:outline-none',
        isInline
          ? 'bg-transparent text-primary border-primary/30 focus:border-accent placeholder:text-primary/40'
          : 'bg-transparent text-ink border-ink/30 focus:border-sun placeholder:text-ink-mute',
      ]}
    />
    {/* Honeypot — opacity+tabindex+aria-hidden (OWASP) */}
    <input
      type="text"
      name="website"
      tabindex={-1}
      autocomplete="off"
      aria-hidden="true"
      class="absolute opacity-0 pointer-events-none size-0"
    />
    <button
      type="submit"
      class:list={[
        'group inline-flex items-center justify-center gap-3 cursor-pointer font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-6 py-3.5 transition-colors focus-visible:outline-2 focus-visible:outline-offset-3',
        isInline
          ? 'bg-primary text-bone hover:bg-accent focus-visible:outline-accent'
          : 'bg-bone text-primary hover:bg-sun focus-visible:outline-sun',
      ]}
    >
      Subscribe
      <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>
  <p
    class:list={[
      'mt-4 font-body-sm text-[0.8125rem]',
      isInline ? 'text-primary/50' : 'text-ink-mute',
    ]}
    data-newsletter-status
    aria-live="polite"
  ></p>
</form>
