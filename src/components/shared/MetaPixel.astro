---
// Meta (Facebook) Pixel - base code + PageView.
// Activates only when PUBLIC_FB_PIXEL_ID is set at build time (it's a
// public, client-side value, so build-time inlining via import.meta.env
// is correct here). Renders nothing when unset, so it's safe to ship
// before the ID exists.
const pixelId = import.meta.env.PUBLIC_FB_PIXEL_ID;
---

{
  pixelId && (
    <>
      <script is:inline define:vars={{ pixelId }}>
        {`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init', pixelId);fbq('track', 'PageView');`}
      </script>
      <noscript>
        <img
          height="1"
          width="1"
          style="display:none"
          src={`https://www.facebook.com/tr?id=${pixelId}&ev=PageView&noscript=1`}
          alt=""
        />
      </noscript>
    </>
  )
}
