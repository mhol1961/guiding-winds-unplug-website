---
import NewsletterSignup from './NewsletterSignup.astro';

const year = new Date().getFullYear();

const navCols = [
  {
    title: 'Voyages',
    items: [
      { label: 'British Virgin Islands', href: '/voyages/british-virgin-islands' },
      { label: 'Bahamas', href: '/voyages/bahamas' },
      { label: 'Italy', href: '/voyages/italy' },
      { label: 'Greece', href: '/voyages/greece' },
      { label: 'Croatia', href: '/voyages/croatia' },
      { label: 'All 14 weeks', href: '/calendar' },
    ],
  },
  {
    title: 'Plan',
    items: [
      { label: 'What is aboard', href: '/aboard' },
      { label: 'Our story', href: '/about' },
      { label: 'Journal', href: '/journal' },
      { label: 'FAQ', href: '/faq' },
      { label: 'Inquire', href: '/inquire' },
    ],
  },
  {
    title: 'Fine print',
    items: [
      { label: 'Privacy', href: '/privacy' },
      { label: 'Terms', href: '/terms' },
    ],
  },
];
---

<footer class="bg-primary text-ink relative overflow-hidden">
  {/* Subtle sun-gold hairline at the very top — a flash of golden hour
       between bone and dark. */}
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sun/40 to-transparent" aria-hidden="true"></div>

  <div class="max-w-[1400px] mx-auto px-7 lg:px-14 pt-24 lg:pt-32 pb-14">
    {/* Top — big brand line + newsletter (full-width treatment, not a card) */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-14 lg:gap-20 pb-16 lg:pb-20 border-b border-ink/10">
      <div class="lg:col-span-7">
        <a
          href="/"
          class="block group mb-6"
          aria-label="Guiding Winds Unplug — home"
        >
          <img
            src="/img/brand/logo.png"
            alt=""
            width="80"
            height="80"
            class="size-16 lg:size-20 object-contain mb-5 group-hover:opacity-85 transition-opacity"
            decoding="async"
            loading="lazy"
          />
          <span
            class="block font-display text-[2.5rem] lg:text-[3.5rem] leading-[0.95] tracking-[-0.025em] text-ink"
            style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
          >
            Guiding Winds
            <span class="italic block sm:inline text-ink/85" style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;">Unplug.</span>
          </span>
        </a>
        <p class="font-body-lg text-[1.0625rem] leading-[1.65] text-ink/75 max-w-md">
          Off-grid catamaran voyages for eight cabins, twelve guests. From the
          British Virgin Islands to the Mediterranean. Captained by Clint
          Kendall, hosted by Dodie Kendall.
        </p>
      </div>

      <div class="lg:col-span-5">
        <NewsletterSignup variant="footer" />
      </div>
    </div>

    {/* Middle — three nav columns */}
    <nav
      class="grid grid-cols-2 md:grid-cols-3 gap-10 lg:gap-16 pt-14 pb-14 border-b border-ink/10"
      aria-label="Footer"
    >
      {
        navCols.map((col) => (
          <div>
            <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-ink-soft mb-6">
              {col.title}
            </p>
            <ul class="flex flex-col gap-3.5">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="font-body-md text-[1rem] text-ink/85 hover:text-sun transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>

    {/* Bottom — copyright + social */}
    <div class="pt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      <p class="font-body-sm text-[0.8125rem] text-ink-mute">
        © {year} Guiding Winds Unplug. Made on the water.
      </p>
      <div class="flex items-center gap-5" aria-label="Social">
        <a
          href="https://instagram.com/guidingwinds"
          rel="me noopener"
          target="_blank"
          aria-label="Instagram"
          class="text-ink-soft hover:text-sun transition-colors"
        >
          <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="5" />
            <circle cx="12" cy="12" r="4" />
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a
          href="https://youtube.com/@guidingwinds"
          rel="me noopener"
          target="_blank"
          aria-label="YouTube"
          class="text-ink-soft hover:text-sun transition-colors"
        >
          <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="5" width="20" height="14" rx="3" />
            <path d="M10 9.5v5l4.5-2.5L10 9.5z" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a
          href="mailto:dodie@guidingwinds-unplug.com"
          aria-label="Email"
          class="text-ink-soft hover:text-sun transition-colors"
        >
          <svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <path d="M3 7l9 6 9-6" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
