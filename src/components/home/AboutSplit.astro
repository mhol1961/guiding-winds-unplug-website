---
import { Play } from 'lucide-react';
---

<section class="bg-primary text-ink border-t border-hairline">
  <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-24 sm:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      {/* Left — text column */}
      <div class="lg:col-span-5">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-6">
          The crew
        </p>
        <h2
          class="font-h2 text-ink leading-[1.05] tracking-[-0.02em] font-normal text-balance"
          style="font-size: clamp(2rem, 3.5vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
        >
          Two captains.
          <span
            class="block italic mt-2"
            style="font-variation-settings: 'opsz' 72, 'SOFT' 50, 'WONK' 1;"
          >
            One slow life.
          </span>
        </h2>
        <div class="mt-8 space-y-5 font-body-lg text-[1.0625rem] leading-[1.7] text-ink-soft">
          <p>
            Clint runs the boat. USCG-licensed, ten years in the chain, a
            decade more on smaller water. He reads weather the way other
            people read the news.
          </p>
          <p>
            Dodie runs everything else. A galley that produces a different
            cuisine every dinner without ever announcing the theme. A
            morning practice on deck if you want it. A quiet day if you
            don't.
          </p>
          <p>
            Together they run fourteen weeks a year, eight cabins each.
            They do not run hundreds. The boat goes where the day-charter
            crowds don't.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 mt-10">
          <a
            href="/calendar"
            class="inline-flex items-center justify-center cursor-pointer bg-accent text-ink font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-accent-hot transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
          >
            Hold a Cabin
          </a>
          <a
            href="/about"
            class="inline-flex items-center font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-ink-soft hover:text-accent transition-colors self-center"
          >
            Read more →
          </a>
        </div>
      </div>

      {/* Right — image / video well */}
      <div class="lg:col-span-7">
        <a
          href="/about"
          class="group relative block aspect-[4/5] lg:aspect-[3/4] overflow-hidden focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
          style="background: linear-gradient(135deg, #0E3F47 0%, #161412 60%, #0A0A0A 100%);"
          aria-label="Watch the 2:48 film — a week aboard"
        >
          {/* Faint horizon line */}
          <div class="absolute inset-x-0 top-[55%] h-px bg-ink/15" aria-hidden="true"></div>
          {/* Play button — circle in the optical center */}
          <div class="absolute inset-0 grid place-items-center">
            <div class="grid place-items-center size-24 lg:size-32 rounded-full bg-bone/15 backdrop-blur-md transition-transform duration-500 group-hover:scale-110">
              <Play className="size-8 lg:size-10 text-ink fill-ink ml-1" strokeWidth={1} />
            </div>
          </div>
          {/* Caption */}
          <div class="absolute bottom-6 left-6 right-6">
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-ink/85">
              Watch the film · 2:48 · A week aboard
            </p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>
