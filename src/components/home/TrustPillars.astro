---
// Five reasons-to-trust as a horizontal hairline-divided strip rather
// than boxed grid. Closer to Black Tomato's "Why Black Tomato?" pattern
// — five line-art SVG icons (small, sub-scale) paired with text labels
// and a 1-line body, divided by hairlines.
import { Star, Wallet, Clock, LifeBuoy, Waves } from 'lucide-react';

const pillars = [
  {
    Icon: Star,
    label: 'Five-star hosts',
    body: 'Two captains, fourteen weeks a year. We sail every voyage personally.',
  },
  {
    Icon: Wallet,
    label: 'All-inclusive',
    body: 'Meals, premium bar, gear, fuel, dockage. One number, no upsell at sundown.',
  },
  {
    Icon: Clock,
    label: '72-hour holds',
    body: 'No deposit to reserve a cabin. Reply when you decide.',
  },
  {
    Icon: LifeBuoy,
    label: 'On-the-boat support',
    body: 'Experienced captain at the helm, fully insured, daily safety checks.',
  },
  {
    Icon: Waves,
    label: 'The right to unplug',
    body: 'Starlink is on by default. Off by Wednesday if you want it.',
  },
];
---

<section class="bg-bone text-primary py-24 sm:py-32 border-t border-rule">
  <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
    <div class="text-center mb-16">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70">
        Why guests come back
      </p>
    </div>

    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 divide-y sm:divide-y-0 sm:divide-x divide-rule border-y border-rule">
      {
        pillars.map(({ Icon, label, body }) => (
          <li class="p-7 lg:p-8 flex flex-col">
            <Icon className="size-5 text-sun mb-5" strokeWidth={1.5} />
            <p class="font-label-caps uppercase tracking-[0.22em] text-[0.6875rem] font-semibold text-primary mb-3">
              {label}
            </p>
            <p class="font-body-md text-[0.9375rem] leading-[1.6] text-primary/70 text-balance">{body}</p>
          </li>
        ))
      }
    </ul>

    <div class="mt-12 text-center">
      <p class="font-body-md text-[0.9375rem] text-primary/70">
        100% five-star reviews · Currently 11 of 14 voyages full for the 2027 sailing year
      </p>
    </div>
  </div>
</section>
