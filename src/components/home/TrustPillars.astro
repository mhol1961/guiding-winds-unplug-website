---
import { Star, Wallet, Clock, LifeBuoy, Waves } from 'lucide-react';

const pillars = [
  {
    Icon: Star,
    label: 'Five-Star Hosts',
    body: 'Two captains, fourteen weeks a year. We sail every voyage personally.',
  },
  {
    Icon: Wallet,
    label: 'All-Inclusive Pricing',
    body: 'Meals, premium bar, gear, fuel, dockage. One number, no upsell at sundown.',
  },
  {
    Icon: Clock,
    label: '72-Hour Holds',
    body: 'No deposit to reserve a cabin. Reply when you decide.',
  },
  {
    Icon: LifeBuoy,
    label: 'On-the-Boat Support',
    body: 'USCG captain at the helm, fully insured, daily safety checks.',
  },
  {
    Icon: Waves,
    label: 'The Right to Unplug',
    body: 'Starlink is on by default. Off by Wednesday if you want it.',
  },
];
---

<section class="bg-bone text-primary border-t border-primary/10">
  <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-20 sm:py-28">
    <div class="text-center mb-14">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-primary/55">
        Why guests come back
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8">
      {
        pillars.map(({ Icon, label, body }) => (
          <div class="flex flex-col">
            <Icon className="size-7 text-accent mb-5" strokeWidth={1.25} />
            <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-primary mb-2">
              {label}
            </p>
            <p class="font-body-md text-[0.9375rem] leading-[1.55] text-primary/70">{body}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-16 pt-8 border-t border-primary/10 text-center">
      <p class="font-body-sm text-[0.8125rem] text-primary/55">
        100% five-star reviews · Verified Trustpilot · Currently 14 of 14 voyages full for the 2025 sailing year
      </p>
    </div>
  </div>
</section>
