---
// Quiet credential strip on bone - hairline above and below, plain
// label-caps with sun-gold dots. Per Black Tomato: trust signals at
// the bottom of the page in a restrained press/awards strip, never
// screaming on the hero.
const credentials = [
  'USCG Master 100-Ton · Captain Clint Kendall',
  'RYA Yachtmaster Offshore',
];
---

<section class="bg-bone text-primary py-10 lg:py-12 border-y border-rule">
  <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
    <ul class="flex flex-wrap items-center justify-center lg:justify-between gap-x-10 gap-y-4">
      {
        credentials.map((c) => (
          <li class="flex items-center gap-2.5">
            <span class="block size-[5px] bg-sun rounded-full" aria-hidden="true"></span>
            <span class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-primary/70">
              {c}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
