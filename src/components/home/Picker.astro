---
import { getCollection } from 'astro:content';

const voyages = await getCollection('voyages');
const order: Record<string, number> = { caribbean: 0, bahamas: 1, mediterranean: 2 };
const sorted = voyages.sort((a, b) => order[a.data.region] - order[b.data.region]);

// Per-voyage destination photography. BVI uses Dodie's real iPhone shot of
// a catamaran at a green headland. The other four use destination-specific
// stock photography (Unsplash, free commercial use) until Dodie's
// Mediterranean and Bahamas photo library is integrated.
const heroFor: Record<string, { src: string; alt: string }> = {
  'british-virgin-islands': {
    src: '/img/source/hero/01-catamaran-green-headland.jpg',
    alt: 'Catamaran sailing past a green tropical headland in the British Virgin Islands',
  },
  bahamas: {
    src: '/img/stock/voyages/bahamas/bahamas-hope-town-lighthouse-hero.jpg',
    alt: 'Hope Town candy-striped lighthouse rising over the Abacos waterfront',
  },
  italy: {
    src: '/img/stock/voyages/italy/italy-amalfi-coast-hero.jpg',
    alt: 'Pastel houses of an Amalfi coast village seen from the water',
  },
  greece: {
    src: '/img/stock/voyages/greece/greece-santorini-caldera-hero.jpg',
    alt: 'Whitewashed Cycladic village above the Santorini caldera at sunset',
  },
  croatia: {
    src: '/img/stock/voyages/croatia/croatia-hvar-harbor-hero.jpg',
    alt: 'Stone harbor town on the Dalmatian coast of Croatia',
  },
};

const regionLabel: Record<string, string> = {
  caribbean: 'Caribbean',
  bahamas: 'Bahamas',
  mediterranean: 'Mediterranean',
};
---

<section class="bg-paper text-primary py-24 sm:py-32 lg:py-40 border-t border-primary/10">
  <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14 lg:mb-20 max-w-4xl">
      <div>
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-5">
          The 2027 voyages
        </p>
        <h2
          class="font-display font-light text-balance leading-[1.05] tracking-[-0.025em]"
          style="font-size: clamp(2rem, 4vw + 1rem, 3.25rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
        >
          Five regions. Pick
          <span class="italic" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
            the water
          </span>
          you've been thinking about.
        </h2>
      </div>
    </div>

    {/* Portrait 9:16 magazine-cover trip cards. The signature component. */}
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-5 lg:gap-6">
      {
        sorted.map((voyage) => {
          const weeks = voyage.data.availableWeeks.length;
          const totalCabins = voyage.data.availableWeeks.reduce(
            (sum, w) => sum + w.cabinsAvailable,
            0,
          );
          const hero = heroFor[voyage.data.slug] ?? heroFor['british-virgin-islands'];
          return (
            <a
              href={`/voyages/${voyage.data.slug}`}
              class="group flex flex-col focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
              aria-label={`${voyage.data.name} voyage detail`}
            >
              {/* Image — portrait 9:16. The magazine-cover ratio. */}
              <div class="relative overflow-hidden aspect-[9/14] mb-5 bg-primary/5">
                <img
                  src={hero.src}
                  alt={hero.alt}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
                />
                {/* Subtle bottom darken for the meta strip readability */}
                <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-primary/30 to-transparent pointer-events-none" aria-hidden="true"></div>
                {/* Meta tag — region in the top-left like a magazine kicker */}
                <span class="absolute top-4 left-4 font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold text-bone/95 bg-primary/40 backdrop-blur-sm px-2.5 py-1.5">
                  {regionLabel[voyage.data.region]}
                </span>
                {/* Availability chip — bottom-right, plain type */}
                <span class="absolute bottom-4 right-4 font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold text-bone tabular-nums">
                  {totalCabins} cabins · {weeks} {weeks === 1 ? 'wk' : 'wks'}
                </span>
              </div>

              {/* Below-image type — magazine-cover style */}
              <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary/55">
                {voyage.data.nights} nights · {voyage.data.country}
              </p>
              <h3
                class="font-display text-[1.375rem] leading-[1.1] tracking-[-0.015em] font-normal mt-2 group-hover:text-accent transition-colors text-balance"
                style="font-variation-settings: 'opsz' 36, 'SOFT' 30, 'WONK' 0;"
              >
                {voyage.data.name}
              </h3>
              <p class="font-body-md text-[0.9375rem] text-primary/65 mt-3 leading-[1.5]">
                From ${voyage.data.pricePerGuestUSD.toLocaleString()} per guest
              </p>
              <span class="mt-4 inline-flex items-center gap-2 font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-accent group-hover:gap-3 transition-all">
                Explore voyage
                <svg viewBox="0 0 16 16" class="size-3" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </a>
          );
        })
      }
    </div>

    <div class="mt-16 pt-10 border-t border-primary/10 flex items-center justify-between flex-wrap gap-5">
      <p class="font-body-md text-[1rem] text-primary/65">
        14 weeks total across the 2027 calendar.
      </p>
      <a
        href="/calendar"
        class="group inline-flex items-center gap-3 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold text-primary border-b-2 border-accent pb-1 hover:text-accent transition-colors"
      >
        View Full Calendar
        <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
