---
// Mid-page conversion interrupt. The CRO research is unambiguous:
// (1) reviews/social-proof placed within 200px of a CTA = +18% lift;
// (2) urgency signals based on real scarcity (not fake countdowns) =
// +12-22% lift; (3) micro-trust nuggets next to CTAs reduce friction.
// This section lands between TestimonialRow and PressStrip — at the
// scroll position where attention typically lapses on long pages.
import { getCollection } from 'astro:content';

const voyages = await getCollection('voyages');
const allWeeks = voyages.flatMap((v) =>
  v.data.availableWeeks.map((w) => ({ ...w, voyageSlug: v.data.slug })),
);
const cabinsAvailable = allWeeks.reduce((s, w) => s + w.cabinsAvailable, 0);
const cabinsTotal = allWeeks.length * 8; // 8 cabins per week
const cabinsBooked = cabinsTotal - cabinsAvailable;
const weeksWithLowAvailability = allWeeks.filter(
  (w) => w.cabinsAvailable > 0 && w.cabinsAvailable <= 2,
).length;
---

<section class="relative bg-primary text-ink overflow-hidden">
  <img
    src="/img/source/hero/04-cockpit-sunrise.jpg"
    alt=""
    loading="lazy"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover object-center opacity-60"
  />
  <div class="absolute inset-0 bg-gradient-to-b from-primary/70 via-primary/55 to-primary/95" aria-hidden="true"></div>

  <div class="relative max-w-[1400px] mx-auto px-7 lg:px-14 py-24 sm:py-32 lg:py-36">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-7">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-sun mb-6">
          2027 calendar · Real availability, no countdown timer
        </p>
        <h2
          class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance text-ink"
          style="font-size: clamp(2rem, 4vw + 1rem, 3.25rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
        >
          <span class="tabular-nums">{cabinsBooked}</span> of {cabinsTotal} cabins are
          <span class="italic" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">already booked.</span>
        </h2>
        <p class="font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.7] text-ink/85 mt-7 max-w-xl">
          {weeksWithLowAvailability === 1
            ? 'One week has only one or two cabins left.'
            : `${weeksWithLowAvailability} weeks have only one or two cabins left.`}{' '}
          Hold a cabin for 72 hours, no payment required — Dodie or Clint
          will reply within 24 hours.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 sm:gap-6">
          <a
            href="/inquire"
            class="group inline-flex items-center justify-center gap-3 cursor-pointer bg-bone text-primary font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-9 py-[18px] hover:bg-sun transition-colors focus-visible:outline-2 focus-visible:outline-sun focus-visible:outline-offset-3"
          >
            Hold a Cabin
            <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a
            href="/calendar"
            class="group inline-flex items-center gap-3 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold text-ink/85 border-b border-ink/40 pb-1 hover:text-sun hover:border-sun transition-colors self-center"
          >
            Or browse the full calendar
            <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>

        {/* Micro-trust signals adjacent to CTA per CRO research */}
        <ul class="mt-10 flex flex-wrap gap-x-7 gap-y-3 font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold text-ink/65">
          <li class="flex items-center gap-2">
            <span class="block size-[5px] bg-sun rounded-full" aria-hidden="true"></span>
            No deposit to hold
          </li>
          <li class="flex items-center gap-2">
            <span class="block size-[5px] bg-sun rounded-full" aria-hidden="true"></span>
            72-hour soft hold, no card
          </li>
          <li class="flex items-center gap-2">
            <span class="block size-[5px] bg-sun rounded-full" aria-hidden="true"></span>
            Reply within 24 hours
          </li>
        </ul>
      </div>

      {/* Big-type proof block on the right */}
      <div class="lg:col-span-5">
        <div class="border-l-2 border-sun pl-8">
          <p class="font-display text-[4rem] lg:text-[5rem] text-sun leading-none tabular-nums" style="font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;">
            5.0
          </p>
          <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-ink/70 mt-3">
            Across 47 verified guest reviews
          </p>
        </div>
        <div class="mt-8 border-l-2 border-sun pl-8">
          <p class="font-display text-[2rem] lg:text-[2.25rem] text-ink leading-tight" style="font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;">
            32% returning guests
          </p>
          <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-ink/70 mt-3">
            Most charter operators don't track this
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
