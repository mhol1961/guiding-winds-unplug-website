---
// Full-bleed cinematic hero. Crossfades 4 Seedance 2 video reels with
// real-photo poster fallbacks. Honors prefers-reduced-motion (videos
// don't autoplay; the first scene's poster image is shown still).

interface Scene {
  videoSrc?: string;
  videoSrcPortrait?: string;
  posterSrc: string;
  alt: string;
}

interface Props {
  scenes?: Scene[];
  eyebrow: string;
  headlinePrefix: string;
  headlineEmphasis: string;
  headlineSuffix?: string;
  subline: string;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  trustItems: string[];
}

const {
  scenes = [
    {
      videoSrc: '/media/hero/hero-bvi-01.mp4',
      videoSrcPortrait: '/media/hero/hero-bvi-01-portrait.mp4',
      posterSrc: '/img/source/hero/02-sunset-catamaran-anchorage.jpg',
      alt: 'A catamaran at anchor at sunset in the Caribbean, warm orange sky reflecting off glassy water',
    },
    {
      videoSrc: '/media/hero/hero-bahamas-02.mp4',
      videoSrcPortrait: '/media/hero/hero-bahamas-02-portrait.mp4',
      posterSrc: '/img/stock/voyages/bahamas/bahamas-hope-town-lighthouse-hero.jpg',
      alt: 'Dawn approach to a pink-sand spit in the Abacos',
    },
    {
      videoSrc: '/media/hero/hero-greece-03.mp4',
      videoSrcPortrait: '/media/hero/hero-greece-03-portrait.mp4',
      posterSrc: '/img/stock/voyages/greece/greece-santorini-caldera-hero.jpg',
      alt: 'A whitewashed Cycladic village climbing a hillside above a calm Aegean cove, a blue-domed church and magenta bougainvillea catching the late sun',
    },
    {
      videoSrc: '/media/hero/hero-deck-04.mp4',
      videoSrcPortrait: '/media/hero/hero-deck-04-portrait.mp4',
      posterSrc: '/img/stock/hero/hero-sunset-teak-deck-04.jpg',
      alt: 'A lit brass hurricane lantern and an open book on a teak deck at sunset with anamorphic lens flare',
    },
  ],
  eyebrow,
  headlinePrefix,
  headlineEmphasis,
  headlineSuffix = '',
  subline,
  primaryCta,
  secondaryCta,
  trustItems,
} = Astro.props;

// Seedance renders are 5s; crossfade duration matches so each scene
// plays once before fading to the next.
const sceneDuration = 5.5;
const totalDuration = sceneDuration * scenes.length;
---

<section class="hero relative w-full min-h-[100dvh] overflow-hidden bg-primary text-bone">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    {
      scenes.map((scene, i) => (
        <div
          class="hero-scene absolute inset-0 opacity-0"
          style={`--i: ${i}; --total: ${scenes.length}; --dur: ${totalDuration}s;`}
        >
          {scene.videoSrc ? (
            <video
              autoplay
              muted
              loop
              playsinline
              preload={i === 0 ? 'auto' : 'metadata'}
              poster={scene.posterSrc}
              class="absolute inset-0 w-full h-full object-cover"
            >
              {scene.videoSrcPortrait && (
                <source media="(max-aspect-ratio: 1/1)" src={scene.videoSrcPortrait} type="video/mp4" />
              )}
              <source src={scene.videoSrc} type="video/mp4" />
            </video>
          ) : (
            <img
              src={scene.posterSrc}
              alt=""
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              fetchpriority={i === 0 ? 'high' : 'auto'}
              class="absolute inset-0 w-full h-full object-cover"
            />
          )}
        </div>
      ))
    }
    <div class="absolute inset-0 bg-gradient-to-b from-primary/40 via-primary/10 via-50% to-primary/90"></div>
  </div>

  <div class="relative z-10 min-h-[100dvh] flex flex-col">
    <div class="flex-1 flex items-end pb-24 lg:pb-32 px-7 lg:px-14 pt-32">
      <div class="max-w-[1400px] w-full mx-auto">
        <div class="max-w-4xl">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.75rem] font-semibold text-bone/90 mb-8">
            {eyebrow}
          </p>
          <h1
            class="font-display text-bone font-light text-pretty leading-[0.95] tracking-[-0.03em]"
            style="font-size: clamp(2.75rem, 7.5vw + 1rem, 7rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
          >
            {headlinePrefix}
            <span
              class="italic block sm:inline"
              style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;"
            >
              {headlineEmphasis}
            </span>
            {headlineSuffix}
          </h1>
          <p class="font-body-lg text-[1.0625rem] lg:text-[1.1875rem] leading-[1.6] text-bone/90 mt-8 max-w-[58ch]">
            {subline}
          </p>
          <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 mt-10 lg:mt-12">
            <a
              href={primaryCta.href}
              class="group inline-flex items-center justify-center gap-3 cursor-pointer bg-accent text-primary font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-9 py-[18px] hover:bg-accent-hot hover:text-bone transition-colors focus-visible:outline-2 focus-visible:outline-bone focus-visible:outline-offset-3"
            >
              {primaryCta.label}
              <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <a
              href={secondaryCta.href}
              class="group inline-flex items-center gap-3 cursor-pointer text-bone/80 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold pb-1 border-b border-bone/30 hover:text-bone hover:border-bone transition-all"
            >
              {secondaryCta.label}
              <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-bone/15 backdrop-blur-md bg-primary/30">
      <div class="max-w-[1400px] mx-auto px-7 lg:px-14 py-5 flex flex-wrap items-center gap-x-10 gap-y-3">
        {
          trustItems.map((item) => (
            <span class="inline-flex items-center gap-2.5 font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-bone/85">
              <span class="block size-[6px] bg-accent rounded-full" aria-hidden="true" />
              {item}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* Crossfade: each scene fades in for ~10% of the cycle and out at the
     end of its window. Scenes are staggered via animation-delay so they
     play one at a time. */
  .hero-scene {
    animation: hero-fade var(--dur) infinite;
    animation-delay: calc(var(--i) * (var(--dur) / var(--total) * -1));
    will-change: opacity;
  }
  @keyframes hero-fade {
    0% { opacity: 0; }
    3% { opacity: 1; }
    23% { opacity: 1; }
    28% { opacity: 0; }
    100% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-scene { animation: none; }
    .hero-scene:first-child { opacity: 1; }
    .hero-scene video { display: none; }
  }
</style>
