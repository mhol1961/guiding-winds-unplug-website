---
// Full-bleed cinematic crossfade hero. Four scenes that loop. When a real
// video file isn't present, falls back to a CSS gradient that evokes the
// destination — the site must hold without photography per ADR-011.
// Honors prefers-reduced-motion via @media in the embedded style block.
interface Scene {
  /** Optional video src — when omitted, the gradient + image fallback render. */
  videoSrc?: string;
  imageSrc?: string;
  /** Used for both <img alt> and aria-label on the slide. */
  alt: string;
  /** CSS gradient used until a real photo/video arrives. */
  fallbackGradient: string;
}

interface Props {
  scenes?: Scene[];
  eyebrow: string;
  headlinePrefix: string;
  headlineEmphasis: string;
  headlineSuffix?: string;
  subline: string;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  trustItems: string[];
}

const {
  scenes = [
    {
      alt: 'Glass water in the British Virgin Islands at sunrise',
      fallbackGradient:
        'linear-gradient(160deg, #0E3F47 0%, #0A0A0A 55%, #2A1F1A 100%)',
    },
    {
      alt: 'A catamaran anchored off pink sand in the Bahamas',
      fallbackGradient:
        'linear-gradient(160deg, #C92E1C 0%, #2A1F1A 55%, #0A0A0A 100%)',
    },
    {
      alt: 'A catamaran in a Greek cove with cliffs above',
      fallbackGradient:
        'linear-gradient(180deg, #1F1B17 0%, #0A0A0A 60%, #0E3F47 100%)',
    },
    {
      alt: 'Sunset on deck with two glasses on a teak table',
      fallbackGradient:
        'linear-gradient(160deg, #E13F2A 0%, #1F1B17 55%, #0A0A0A 100%)',
    },
  ],
  eyebrow,
  headlinePrefix,
  headlineEmphasis,
  headlineSuffix = '',
  subline,
  primaryCta,
  secondaryCta,
  trustItems,
} = Astro.props;

// Each scene crossfade lasts ~7s; 4 scenes; total cycle ~28s.
const sceneDuration = 7;
const totalDuration = sceneDuration * scenes.length;
---

<section class="hero relative w-full min-h-[100dvh] overflow-hidden bg-primary text-ink">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    {
      scenes.map((scene, i) => (
        <div
          class="hero-scene absolute inset-0 opacity-0"
          style={`
            --i: ${i};
            --total: ${scenes.length};
            --dur: ${totalDuration}s;
            background: ${scene.fallbackGradient};
            background-size: cover;
            background-position: center;
          `}
        >
          {scene.imageSrc && (
            <img
              src={scene.imageSrc}
              alt=""
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
              fetchpriority={i === 0 ? 'high' : 'auto'}
              class="absolute inset-0 w-full h-full object-cover"
            />
          )}
          {scene.videoSrc && (
            <video
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              class="absolute inset-0 w-full h-full object-cover"
            >
              <source src={scene.videoSrc} type="video/mp4" />
            </video>
          )}
        </div>
      ))
    }
    {/* Bottom gradient ramp for legibility — no shadows per DESIGN.md. */}
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/30 to-primary/90"></div>
  </div>

  {/* Foreground content */}
  <div class="relative z-10 min-h-[100dvh] flex flex-col">
    <div class="flex-1 flex items-end pb-32 px-7 lg:px-14 pt-32">
      <div class="max-w-[1320px] w-full mx-auto">
        <div class="max-w-3xl">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink/80 mb-8">
            {eyebrow}
          </p>
          <h1
            class="font-display text-ink font-light text-balance leading-[0.95] tracking-[-0.03em]"
            style="font-size: clamp(3rem, 8vw + 1rem, 6.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
          >
            {headlinePrefix}
            <span
              class="italic"
              style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 1;"
            >
              {headlineEmphasis}
            </span>
            {headlineSuffix}
          </h1>
          <p class="font-body-lg text-[1.0625rem] leading-[1.65] text-ink/85 mt-8 max-w-[58ch]">
            {subline}
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mt-12">
            <a
              href={primaryCta.href}
              class="inline-flex items-center justify-center cursor-pointer bg-accent text-ink font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-accent-hot transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
            >
              {primaryCta.label}
            </a>
            <a
              href={secondaryCta.href}
              class="inline-flex items-center justify-center cursor-pointer bg-transparent text-ink border border-ink/30 font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-ink hover:text-primary transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
            >
              {secondaryCta.label}
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* Trust strip */}
    <div class="relative">
      <div class="bg-primary/30 backdrop-blur-md border-t border-ink/10">
        <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-5 flex flex-wrap items-center gap-x-10 gap-y-3">
          {
            trustItems.map((item) => (
              <span class="inline-flex items-center gap-2 font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-ink/85">
                <span class="block size-[6px] bg-accent rounded-full" aria-hidden="true" />
                {item}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style define:vars={{ totalDuration: `${totalDuration}s`, sceneCount: scenes.length, sceneDuration: `${sceneDuration}s` }}>
  /* Crossfade: each scene fades in for ~15% of its slot, holds, fades out.
     Ken Burns layered on top via scale transform. */
  .hero-scene {
    animation: hero-fade var(--dur) infinite;
    animation-delay: calc(var(--i) * (var(--dur) / var(--total) * -1));
    will-change: opacity, transform;
  }

  @keyframes hero-fade {
    0% { opacity: 0; transform: scale(1); }
    5% { opacity: 1; }
    25% { opacity: 1; transform: scale(1.06); }
    30% { opacity: 0; transform: scale(1.06); }
    100% { opacity: 0; transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scene {
      animation: none;
    }
    .hero-scene:first-child {
      opacity: 1;
    }
  }
</style>
