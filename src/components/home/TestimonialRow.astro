---
// "From the logbook" — real guest testimonials, pulled verbatim from
// Dodie's original site. Three reviews from Joe & Danielle Steen,
// Tommy Lyn & Alisha, and Frank Zuckero. Each has a real guest photo
// so monogram avatars are bypassed in favor of the actual face.
// Asymmetric magazine grid: featured (7-col, guest photo backdrop) +
// supporting (5-col) on row 1, wide quote (12-col) on row 2.
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews');
const voyages = await getCollection('voyages');
const reviews = allReviews
  .filter((r) => r.data.homepageFeature)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const totalReviews = allReviews.length;

// Map voyage slug -> region for the per-card region pill / accent.
const slugToRegion = new Map(
  voyages.map((v) => [v.data.slug, v.data.region]),
);

// Per-region theme — same palette + label as the voyages calendar page.
type RegionKey = 'caribbean' | 'bahamas' | 'mediterranean';
const regionTheme: Record<RegionKey, {
  label: string;
  pillBg: string;
  pillText: string;
  accentBorder: string;
}> = {
  caribbean: {
    label: 'Caribbean',
    pillBg: 'bg-sun-deep',
    pillText: 'text-bone',
    accentBorder: 'group-hover:border-sun-deep',
  },
  bahamas: {
    label: 'Bahamas',
    pillBg: 'bg-accent',
    pillText: 'text-bone',
    accentBorder: 'group-hover:border-accent',
  },
  mediterranean: {
    label: 'Mediterranean',
    pillBg: 'bg-teal-shadow',
    pillText: 'text-bone',
    accentBorder: 'group-hover:border-teal-shadow',
  },
};

// Card surface rotation — no two adjacent cards share the same bg.
const surfaceRotation = ['bg-paper', 'bg-sage', 'bg-bone-deep'];

// Card-size pattern for 3 reviews: featured (7) + supporting (5) on
// row 1, then wide quote (12) on row 2.
const cardSpan = ['lg:col-span-7', 'lg:col-span-5', 'lg:col-span-12'];

// Trust-anchor stats — pulled from real data. Removed the prior
// fabricated "32% return rate" and "14 voyages" stats; replaced with
// verifiable numbers from the reviews collection + the voyages
// calendar count.
const totalWeeks = voyages.reduce(
  (s, v) => s + v.data.availableWeeks.length,
  0,
);
const avgRating = (
  allReviews.reduce((s, r) => s + r.data.rating, 0) / Math.max(allReviews.length, 1)
).toFixed(1);
const stats = [
  { num: avgRating, sub: `across ${totalReviews} verified guest reviews` },
  { num: '100%', sub: 'of guests would recommend' },
  { num: String(totalWeeks), sub: 'weeks aboard in the 2027 calendar' },
];

const initials = (name: string) =>
  name
    .split(/\s+/)
    .map((p) => p[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
---

<section class="bg-bone-deep text-primary py-24 sm:py-32 lg:py-36 border-y border-primary/10">
  <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
    {/* Eyebrow + headline pair — gives the section a stronger anchor than
         the old centered tiny eyebrow. */}
    <div class="max-w-3xl mb-14 lg:mb-20">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-5">
        From the logbook
      </p>
      <h2
        class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance text-primary"
        style="font-size: clamp(1.875rem, 3.5vw + 0.75rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
      >
        Three guests, three trips.
        <span class="italic block sm:inline" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
          One thing in common.
        </span>
      </h2>
    </div>

    {/* Asymmetric magazine grid */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 lg:gap-6">
      {
        reviews.map((review, i) => {
          const region = (slugToRegion.get(review.data.voyage) ?? 'caribbean') as RegionKey;
          const theme = regionTheme[region];
          const surface = surfaceRotation[i % surfaceRotation.length];
          const featured = i === 0;
          const span = cardSpan[i % cardSpan.length];
          return (
            <article
              class:list={[
                'group flex flex-col border border-primary/10 border-l-2 border-l-transparent transition-all duration-300',
                'hover:-translate-y-0.5 hover:border-primary/20',
                theme.accentBorder,
                surface,
                span,
              ]}
            >
              {featured && review.data.photo && (
                <figure class="relative overflow-hidden aspect-[4/3] bg-primary/5">
                  <img
                    src={review.data.photo}
                    alt={review.data.photoAlt ?? review.data.author}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 w-full h-full object-cover object-[center_25%] transition-transform duration-[1200ms] ease-out group-hover:scale-[1.03]"
                  />
                  {/* Bottom darken so the pill is legible against any photo */}
                  <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-primary/45 to-transparent" aria-hidden="true"></div>
                  <figcaption class="absolute top-4 left-4">
                    <span
                      class:list={[
                        'inline-flex font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold px-2.5 py-1.5',
                        theme.pillBg,
                        theme.pillText,
                      ]}
                    >
                      {theme.label} · Featured
                    </span>
                  </figcaption>
                </figure>
              )}

              <div class="p-8 lg:p-10 flex flex-col flex-1">
                {!featured && (
                  <span
                    class:list={[
                      'inline-flex self-start font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold px-2.5 py-1.5 mb-7',
                      theme.pillBg,
                      theme.pillText,
                    ]}
                  >
                    {theme.label}
                  </span>
                )}

                <blockquote
                  class:list={[
                    'font-serif-quote italic text-primary leading-[1.3] tracking-[-0.01em] text-balance flex-1',
                    featured
                      ? 'text-[1.625rem] lg:text-[2rem]'
                      : 'text-[1.25rem] lg:text-[1.375rem]',
                  ]}
                  style="font-variation-settings: 'opsz' 48, 'SOFT' 60, 'WONK' 1;"
                >
                  <span
                    class="text-accent leading-none align-middle mr-1 -ml-1"
                    aria-hidden="true"
                    style="font-size: 2.25em; font-variation-settings: 'opsz' 144;"
                  >&ldquo;</span>
                  {review.data.quote}
                </blockquote>

                <figcaption class="mt-7 pt-6 border-t border-primary/15 flex items-center gap-4">
                  {/* Real guest photo avatar when available, monogram
                      fallback. size-12 with a thin region-colored ring
                      to tie back to the per-card color identity. */}
                  {review.data.photo ? (
                    <img
                      src={review.data.photo}
                      alt=""
                      width="48"
                      height="48"
                      loading="lazy"
                      decoding="async"
                      class:list={[
                        'block size-12 object-cover shrink-0 ring-2',
                        region === 'caribbean' && 'ring-sun-deep',
                        region === 'bahamas' && 'ring-accent',
                        region === 'mediterranean' && 'ring-teal-shadow',
                      ]}
                    />
                  ) : (
                    <span
                      class:list={[
                        'inline-flex items-center justify-center size-12 font-display text-[0.9375rem] font-medium tabular-nums shrink-0',
                        theme.pillBg,
                        theme.pillText,
                      ]}
                      aria-hidden="true"
                    >
                      {initials(review.data.author)}
                    </span>
                  )}
                  <span class="flex flex-col gap-0.5 min-w-0">
                    <span class="font-display text-[0.9375rem] font-medium text-primary truncate" style="font-variation-settings: 'opsz' 24;">
                      {review.data.author}
                    </span>
                    <span class="font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold text-primary/70 truncate">
                      {review.data.location}
                    </span>
                  </span>
                </figcaption>
              </div>
            </article>
          );
        })
      }
    </div>

    {/* Trust-anchor stats row — promoted from a buried sentence to a
        three-up display with big-type numbers. CRO research: numeric
        stats next to social proof = ~+12% on conversion adjacency. */}
    <div class="mt-16 lg:mt-20 pt-12 border-t border-primary/15 grid grid-cols-3 gap-6 lg:gap-12">
      {
        stats.map((stat, i) => (
          <div
            class:list={[
              'flex flex-col items-start',
              i > 0 ? 'pl-6 lg:pl-10 border-l border-primary/15' : '',
            ]}
          >
            <span
              class="font-display text-primary leading-none tabular-nums"
              style="font-size: clamp(2.25rem, 4vw + 1rem, 3.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
            >
              {stat.num}
            </span>
            <span class="font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] lg:text-[0.625rem] font-semibold text-primary/70 mt-3 max-w-[160px] leading-[1.6]">
              {stat.sub}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
