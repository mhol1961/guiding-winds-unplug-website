---
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews');
const reviews = allReviews
  .filter((r) => r.data.homepageFeature)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const totalReviews = (await getCollection('reviews')).length;
---

<section class="bg-bone-deep text-primary py-24 sm:py-32 lg:py-40 border-y border-primary/10">
  <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
    <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-16 text-center">
      From the logbook
    </p>

    {/* Four quotes stacked editorial-style with hairline dividers — modeled
         on Black Tomato's compact italic-quote pattern. Each quote is a
         standalone pull-quote, not a card. */}
    <div class="max-w-[820px] mx-auto">
      {
        reviews.map((review, i) => (
          <figure
            class:list={[
              'py-12 lg:py-16',
              i > 0 ? 'border-t border-primary/15' : '',
            ]}
          >
            <blockquote
              class="font-serif-quote italic text-primary text-[1.5rem] lg:text-[2rem] leading-[1.3] tracking-[-0.01em] text-balance"
              style="font-variation-settings: 'opsz' 36, 'SOFT' 60, 'WONK' 1;"
            >
              <span class="text-accent text-[3.5rem] leading-none align-middle mr-1 -ml-2" aria-hidden="true" style="font-variation-settings: 'opsz' 144;">&ldquo;</span>{review.data.quote}
            </blockquote>
            <figcaption class="mt-6 font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary/65">
              <span class="text-primary">{review.data.author}</span>
              <span class="opacity-50 mx-2">·</span>
              {review.data.location}
              <span class="opacity-50 mx-2">·</span>
              {review.data.voyage.replace(/-/g, ' ')}
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="mt-12 lg:mt-16 text-center font-body-md text-[1rem] text-primary/70">
      <span class="font-h3 text-[1.5rem] text-primary mr-2" style="font-variation-settings: 'opsz' 36;">5.0</span>
      across {totalReviews}+ verified reviews · 14 voyages a year · Returning guest rate, 32%
    </p>
  </div>
</section>
