---
// "From the logbook" — testimonial cards in an asymmetric 12-col magazine
// grid. Old version was four identical full-width quotes stacked with
// hairline dividers; that reads as "list of text" and the cream-on-cream
// monotony erased the persuasive lift testimonials are supposed to give.
// New version: per-card contrasting surface, region color identity that
// matches the voyages page (caribbean=sun-gold, bahamas=coral,
// mediterranean=teal), region-keyed destination photo on the featured
// card, hover lift with region-colored left border, and a prominent
// trust-anchor stats row at the bottom.
import { getCollection } from 'astro:content';

const allReviews = await getCollection('reviews');
const voyages = await getCollection('voyages');
const reviews = allReviews
  .filter((r) => r.data.homepageFeature)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const totalReviews = allReviews.length;

// Map voyage slug -> region for the per-card region pill / accent.
const slugToRegion = new Map(
  voyages.map((v) => [v.data.slug, v.data.region]),
);

// Per-region theme — exact same palette + label as the voyages calendar
// page, so a returning visitor recognizes the color identity.
type RegionKey = 'caribbean' | 'bahamas' | 'mediterranean';
const regionTheme: Record<RegionKey, {
  label: string;
  pillBg: string;
  pillText: string;
  accentBorder: string;
  destinationPhoto: string;
  destinationPhotoAlt: string;
}> = {
  caribbean: {
    label: 'Caribbean',
    pillBg: 'bg-sun-deep',
    pillText: 'text-bone',
    accentBorder: 'group-hover:border-sun-deep',
    destinationPhoto: '/img/source/hero/02-sunset-catamaran-anchorage.jpg',
    destinationPhotoAlt: 'Sunset over a catamaran at anchor in the British Virgin Islands',
  },
  bahamas: {
    label: 'Bahamas',
    pillBg: 'bg-accent',
    pillText: 'text-bone',
    accentBorder: 'group-hover:border-accent',
    destinationPhoto: '/img/source/ig/beach-palapa-cove-portrait.jpg',
    destinationPhotoAlt: 'Beach palapa over a pink-sand cove in the Bahamas',
  },
  mediterranean: {
    label: 'Mediterranean',
    pillBg: 'bg-teal-shadow',
    pillText: 'text-bone',
    accentBorder: 'group-hover:border-teal-shadow',
    destinationPhoto: '/img/source/ig/harbor-sunset-moon-portrait.jpg',
    destinationPhotoAlt: 'Mediterranean harbor at sunset with rising moon',
  },
};

// Card surface rotation so no two adjacent cards share the same bg —
// the wall-of-tan complaint applies inside this section too. Surfaces
// are intentionally drawn from the alternating palette already used
// across the rest of the home page.
const surfaceRotation = ['bg-paper', 'bg-sage', 'bg-bone-deep', 'bg-teal-mist'];

// Card-size pattern: 7-5 / 5-7 on lg+. Featured (idx 0) gets the wide
// slot AND the destination photo. Idx 1/2 are 5-col cards. Idx 3 is
// the wide-quote card with no photo, just a giant italic statement.
const cardSpan = ['lg:col-span-7', 'lg:col-span-5', 'lg:col-span-5', 'lg:col-span-7'];

// Trust-anchor stats (Codex CRO note: stats next to social proof
// reduce purchase friction; prior version buried them in a sentence).
const stats = [
  { num: '5.0', sub: `across ${totalReviews}+ verified reviews` },
  { num: '32%', sub: 'guests return within 18 months' },
  { num: '14', sub: 'voyages a year, no more' },
];

const initials = (name: string) =>
  name
    .split(/\s+/)
    .map((p) => p[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
---

<section class="bg-bone-deep text-primary py-24 sm:py-32 lg:py-36 border-y border-primary/10">
  <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
    {/* Eyebrow + headline pair — gives the section a stronger anchor than
         the old centered tiny eyebrow. */}
    <div class="max-w-3xl mb-14 lg:mb-20">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-5">
        From the logbook
      </p>
      <h2
        class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance text-primary"
        style="font-size: clamp(1.875rem, 3.5vw + 0.75rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
      >
        Four weeks. Four guests.
        <span class="italic block sm:inline" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
          One thing in common.
        </span>
      </h2>
    </div>

    {/* Asymmetric magazine grid */}
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-5 lg:gap-6">
      {
        reviews.map((review, i) => {
          const region = (slugToRegion.get(review.data.voyage) ?? 'caribbean') as RegionKey;
          const theme = regionTheme[region];
          const surface = surfaceRotation[i % surfaceRotation.length];
          const featured = i === 0;
          const span = cardSpan[i % cardSpan.length];
          return (
            <article
              class:list={[
                'group flex flex-col border border-primary/10 border-l-2 border-l-transparent transition-all duration-300',
                'hover:-translate-y-0.5 hover:border-primary/20',
                theme.accentBorder,
                surface,
                span,
              ]}
            >
              {featured && (
                <figure class="relative overflow-hidden aspect-[16/9] bg-primary/5">
                  <img
                    src={theme.destinationPhoto}
                    alt={theme.destinationPhotoAlt}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.03]"
                  />
                  <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-primary/40 to-transparent" aria-hidden="true"></div>
                  <figcaption class="absolute top-4 left-4">
                    <span
                      class:list={[
                        'inline-flex font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold px-2.5 py-1.5',
                        theme.pillBg,
                        theme.pillText,
                      ]}
                    >
                      {theme.label} · Featured
                    </span>
                  </figcaption>
                </figure>
              )}

              <div class="p-8 lg:p-10 flex flex-col flex-1">
                {!featured && (
                  <span
                    class:list={[
                      'inline-flex self-start font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold px-2.5 py-1.5 mb-7',
                      theme.pillBg,
                      theme.pillText,
                    ]}
                  >
                    {theme.label}
                  </span>
                )}

                <blockquote
                  class:list={[
                    'font-serif-quote italic text-primary leading-[1.3] tracking-[-0.01em] text-balance flex-1',
                    featured
                      ? 'text-[1.625rem] lg:text-[2rem]'
                      : 'text-[1.25rem] lg:text-[1.375rem]',
                  ]}
                  style="font-variation-settings: 'opsz' 48, 'SOFT' 60, 'WONK' 1;"
                >
                  <span
                    class="text-accent leading-none align-middle mr-1 -ml-1"
                    aria-hidden="true"
                    style="font-size: 2.25em; font-variation-settings: 'opsz' 144;"
                  >&ldquo;</span>
                  {review.data.quote}
                </blockquote>

                <figcaption class="mt-7 pt-6 border-t border-primary/15 flex items-center gap-4">
                  {/* Initials avatar — humanizes the quote without
                      requiring a real photo of a real guest. Region
                      color, monogram, sized for tap-target on mobile. */}
                  <span
                    class:list={[
                      'inline-flex items-center justify-center size-11 font-display text-[0.9375rem] font-medium tabular-nums shrink-0',
                      theme.pillBg,
                      theme.pillText,
                    ]}
                    aria-hidden="true"
                  >
                    {initials(review.data.author)}
                  </span>
                  <span class="flex flex-col gap-0.5 min-w-0">
                    <span class="font-display text-[0.9375rem] font-medium text-primary truncate" style="font-variation-settings: 'opsz' 24;">
                      {review.data.author}
                    </span>
                    <span class="font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold text-primary/70 truncate">
                      {review.data.location}
                    </span>
                  </span>
                </figcaption>
              </div>
            </article>
          );
        })
      }
    </div>

    {/* Trust-anchor stats row — promoted from a buried sentence to a
        three-up display with big-type numbers. CRO research: numeric
        stats next to social proof = ~+12% on conversion adjacency. */}
    <div class="mt-16 lg:mt-20 pt-12 border-t border-primary/15 grid grid-cols-3 gap-6 lg:gap-12">
      {
        stats.map((stat, i) => (
          <div
            class:list={[
              'flex flex-col items-start',
              i > 0 ? 'pl-6 lg:pl-10 border-l border-primary/15' : '',
            ]}
          >
            <span
              class="font-display text-primary leading-none tabular-nums"
              style="font-size: clamp(2.25rem, 4vw + 1rem, 3.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
            >
              {stat.num}
            </span>
            <span class="font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] lg:text-[0.625rem] font-semibold text-primary/70 mt-3 max-w-[160px] leading-[1.6]">
              {stat.sub}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
