---
// Single coral CTA section. The one place the brand goes full color.
// One CTA, no competing buttons, no extra prose.
---

<section class="bg-accent text-ink border-y border-accent-hot/30">
  <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-28 sm:py-36 text-center">
    <h2
      class="font-display text-ink leading-[0.95] tracking-[-0.03em] font-light text-balance"
      style="font-size: clamp(2.5rem, 6vw + 1rem, 5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
    >
      So, ready to
      <span
        class="italic"
        style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 1;"
      >
        sail?
      </span>
    </h2>
    <div class="mt-10">
      <a
        href="/calendar"
        class="inline-flex items-center justify-center cursor-pointer bg-primary text-ink font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-9 py-5 hover:bg-accent-hot hover:outline hover:outline-2 hover:outline-ink hover:outline-offset-[-1px] transition-colors focus-visible:outline-2 focus-visible:outline-ink focus-visible:outline-offset-3"
      >
        Browse Available Weeks
      </a>
    </div>
  </div>
</section>
