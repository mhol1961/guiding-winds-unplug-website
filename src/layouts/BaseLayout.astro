---
import '../styles/global.css';
import SeoHead from '../components/shared/SeoHead.astro';
import Nav from '../components/shared/Nav.astro';
import Footer from '../components/shared/Footer.astro';
import FormHandlers from '../components/shared/form-handlers.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishDate?: string;
  modifiedDate?: string;
  author?: string;
  noindex?: boolean;
  schema?: object | object[];
  /** Make the nav transparent over a hero — call sites that have a full-bleed
   *  hero pass true; everything else uses the default solid nav. */
  transparentNav?: boolean;
}

const { transparentNav = false, ...seoProps } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SeoHead {...seoProps} />
  </head>
  <body class="bg-primary text-ink min-h-screen flex flex-col">
    <Nav transparent={transparentNav} />
    <main class="flex-1 pt-20" data-transparent-nav={transparentNav}>
      <slot />
    </main>
    <Footer />
    <FormHandlers />
  </body>
</html>

<style is:global>
  /* When the nav is transparent over a hero, pull the main content up to
     sit beneath it. Hero sections opt out of the 80px top padding. */
  main[data-transparent-nav='true'] {
    padding-top: 0;
  }
</style>
