---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/shared/PageHero.astro';

const title = 'Field Notes · Stories from Catamaran Voyages | Guiding Winds Unplug';
const description =
  'Quiet pieces on the slow life on the water — guides, field notes, wellness, and the view from behind the boat.';

const allPosts = await getCollection('journal', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';

const categoryLabels: Record<string, string> = {
  guide: 'Guide',
  'field-notes': 'Field Notes',
  wellness: 'Wellness',
  'behind-the-boat': 'Behind the Boat',
};

const categoryFallback: Record<string, string> = {
  guide: '/img/stock/journal/journal-packing-flatlay-01.jpg',
  'field-notes': '/img/stock/journal/journal-bvi-anchorage-aerial-02.jpg',
  wellness: '/img/stock/journal/journal-sunrise-meditation-03.jpg',
  'behind-the-boat': '/img/stock/journal/journal-catamaran-comparison-04.jpg',
};

// Map specific posts to their best-fit hero image from the stock library.
const postHero: Record<string, string> = {
  'what-to-actually-pack': '/img/stock/journal/journal-packing-flatlay-01.jpg',
  'five-bvi-anchorages': '/img/stock/journal/journal-bvi-anchorage-aerial-02.jpg',
  'mornings-at-sea': '/img/stock/journal/journal-sunrise-meditation-03.jpg',
  'catamaran-vs-monohull': '/img/stock/journal/journal-catamaran-comparison-04.jpg',
  'anegada-lobster': '/img/stock/journal/journal-lobster-plate-05.jpg',
};

const schemaGraph = [
  {
    '@type': 'Blog',
    name: 'Field Notes — Guiding Winds Unplug',
    description,
    url: `${baseUrl}/journal`,
    blogPost: posts.slice(0, 10).map((p) => ({
      '@type': 'BlogPosting',
      headline: p.data.title,
      url: `${baseUrl}/journal/${p.id}`,
      datePublished: p.data.publishedAt.toISOString(),
    })),
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Journal', item: `${baseUrl}/journal` },
    ],
  },
];

const categories: Array<keyof typeof categoryLabels> = [
  'guide',
  'field-notes',
  'wellness',
  'behind-the-boat',
];

const featured = posts[0];
const rest = posts.slice(1);
---

<BaseLayout title={title} description={description} transparentNav schema={schemaGraph}>
  <PageHero
    eyebrow="Journal"
    headlinePrefix="Field"
    headlineEmphasis="Notes."
    subline="Quiet pieces on the slow life on the water — packing guides, the anchorages we love, why mornings at sea are the best therapy, and the view from behind the boat."
    heroImage="/img/stock/journal/journal-sunrise-meditation-03.jpg"
    heroImageAlt="A figure sitting on the bow at sunrise, looking out across calm water"
  />

  {/* Category strip */}
  <section class="bg-bone text-primary py-6 border-b border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <nav aria-label="Category filter" class="flex flex-wrap items-center gap-x-8 gap-y-3">
        <span class="font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold text-primary/55">
          Browse
        </span>
        {
          categories.map((cat) => (
            <a
              href={`#${cat}`}
              class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary/75 hover:text-accent transition-colors"
            >
              {categoryLabels[cat]}
            </a>
          ))
        }
      </nav>
    </div>
  </section>

  {/* Featured post — editorial split */}
  {featured && (
    <section class="bg-bone text-primary py-20 lg:py-28 border-b border-rule">
      <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
        <a href={`/journal/${featured.id}`} class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center group">
          <div class="lg:col-span-7 lg:order-2">
            <figure class="relative aspect-[17/10] overflow-hidden bg-primary/5">
              <img src={postHero[featured.id] ?? categoryFallback[featured.data.category]} alt={featured.data.title} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]" />
            </figure>
          </div>
          <div class="lg:col-span-5 lg:order-1">
            <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-sun-deep mb-5">
              Latest · {categoryLabels[featured.data.category]}
            </p>
            <h2
              class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance group-hover:text-accent transition-colors"
              style="font-size: clamp(1.875rem, 3.5vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
            >
              {featured.data.title}
            </h2>
            <p class="font-body-lg text-[1.0625rem] leading-[1.65] text-primary/70 mt-6">
              {featured.data.excerpt}
            </p>
            <p class="font-body-sm text-[0.875rem] text-primary/55 mt-6">
              <time datetime={featured.data.publishedAt.toISOString()}>
                {featured.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>{' '}
              · by {featured.data.author === 'dodie' ? 'Dodie' : featured.data.author === 'clint' ? 'Clint' : 'Guest'}
            </p>
            <span class="mt-7 inline-flex items-center gap-3 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold text-primary border-b-2 border-accent pb-1 group-hover:text-accent transition-colors">
              Read the piece
              <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </div>
        </a>
      </div>
    </section>
  )}

  {/* Rest of posts — 3-col grid */}
  <section class="bg-bone text-primary py-20 lg:py-28">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      {rest.length === 0 && (
        <p class="font-body-lg text-primary/55 text-center py-20">
          More posts arriving through Q3 2026.
        </p>
      )}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-7 gap-y-16">
        {
          rest.map((post) => (
            <article id={post.data.category} class="flex flex-col">
              <a
                href={`/journal/${post.id}`}
                class="block aspect-[16/10] overflow-hidden mb-5 bg-primary/5 group focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
              >
                <img
                  src={postHero[post.id] ?? categoryFallback[post.data.category]}
                  alt={post.data.title}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
                />
              </a>
              <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-sun-deep mb-3">
                {categoryLabels[post.data.category]}
              </p>
              <h3
                class="font-display text-[1.5rem] leading-[1.15] tracking-[-0.015em] font-normal mb-3"
                style="font-variation-settings: 'opsz' 36;"
              >
                <a href={`/journal/${post.id}`} class="hover:text-accent transition-colors">
                  {post.data.title}
                </a>
              </h3>
              <p class="font-body-md text-[0.9375rem] leading-[1.55] text-primary/70 mb-4 text-balance">
                {post.data.excerpt}
              </p>
              <p class="font-body-sm text-[0.8125rem] text-primary/55 mt-auto">
                <time datetime={post.data.publishedAt.toISOString()}>
                  {post.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </time>{' '}
                · by {post.data.author === 'dodie' ? 'Dodie' : post.data.author === 'clint' ? 'Clint' : 'Guest'}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
