---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import NewsletterSignup from '../../components/shared/NewsletterSignup.astro';

export async function getStaticPaths() {
  const posts = await getCollection('journal', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';
const postUrl = `${baseUrl}/journal/${post.id}`;

const categoryLabels: Record<string, string> = {
  guide: 'Guide',
  'field-notes': 'Field Notes',
  wellness: 'Wellness',
  'behind-the-boat': 'Behind the Boat',
};

const categoryGradients: Record<string, string> = {
  guide: 'linear-gradient(135deg, #1F1B17 0%, #0E3F47 100%)',
  'field-notes': 'linear-gradient(135deg, #0E3F47 0%, #161412 100%)',
  wellness: 'linear-gradient(135deg, #161412 0%, #1F1B17 100%)',
  'behind-the-boat': 'linear-gradient(135deg, #C92E1C 0%, #2A1F1A 100%)',
};

const authorName =
  post.data.author === 'dodie' ? 'Dodie Kendall' : post.data.author === 'clint' ? 'Clint Kendall' : 'Guest';

// Real hero photo per post - same mapping the hub uses, fall back to a
// category-appropriate stock image if the specific post hero isn't mapped.
const postHero: Record<string, string> = {
  'what-to-actually-pack': '/img/stock/journal/journal-packing-flatlay-01.jpg',
  'five-bvi-anchorages': '/img/stock/journal/journal-bvi-anchorage-aerial-02.jpg',
  'mornings-at-sea': '/img/stock/journal/journal-sunrise-meditation-03.jpg',
  'catamaran-vs-monohull': '/img/stock/journal/journal-catamaran-comparison-04.jpg',
  'anegada-lobster': '/img/stock/journal/journal-lobster-plate-05.jpg',
};
const heroSrc = postHero[post.id] ?? post.data.heroImage ?? '/img/source/hero/02-sunset-catamaran-anchorage.jpg';
const heroAlt = post.data.heroImageAlt ?? post.data.title;

// Related posts - same category, exclude self, max 3.
const allPosts = await getCollection('journal', ({ data }) => !data.draft);
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);

const schemaGraph = [
  {
    '@type': 'BlogPosting',
    '@id': `${postUrl}#post`,
    headline: post.data.title,
    description: post.data.excerpt,
    image: post.data.heroImage
      ? post.data.heroImage.startsWith('http')
        ? post.data.heroImage
        : `${baseUrl}${post.data.heroImage}`
      : undefined,
    datePublished: post.data.publishedAt.toISOString(),
    dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
    author: { '@type': 'Person', name: authorName },
    publisher: {
      '@type': 'Organization',
      name: 'Guiding Winds Unplug',
      logo: { '@type': 'ImageObject', url: `${baseUrl}/og/logo.png` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
    keywords: post.data.tags.join(', '),
    articleSection: categoryLabels[post.data.category],
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Journal', item: `${baseUrl}/journal` },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
    ],
  },
];

// Optional CTA - link to related voyage if frontmatter specified one.
const relatedVoyageSlug = post.data.relatedVoyage;
---

<PostLayout
  title={post.data.seo.title}
  description={post.data.seo.description}
  publishDate={post.data.publishedAt.toISOString()}
  modifiedDate={post.data.updatedAt?.toISOString()}
  author={authorName}
  category={categoryLabels[post.data.category]}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  schema={schemaGraph}
>
  {/* Article hero - full-bleed real photo with editorial overlay */}
  <article>
    <header class="relative bg-primary text-ink overflow-hidden min-h-[70dvh] lg:min-h-[75dvh] flex flex-col">
      <img
        src={heroSrc}
        alt={heroAlt}
        class="absolute inset-0 w-full h-full object-cover"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-primary/35 via-primary/10 via-45% to-primary/90" aria-hidden="true"></div>
      <div class="relative z-10 flex-1 flex flex-col">
        <div class="flex-1 flex items-end pb-12 lg:pb-16 px-7 lg:px-14 pt-32">
          <div class="max-w-[1200px] w-full mx-auto">
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.75rem] font-semibold text-sun mb-6">
              {categoryLabels[post.data.category]}
            </p>
            <h1
              class="font-display text-ink font-light text-pretty leading-[0.98] tracking-[-0.025em] max-w-4xl"
              style="font-size: clamp(2rem, 5vw + 1rem, 4.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
            >
              {post.data.title}
            </h1>
            <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-ink/75 mt-8">
              <time datetime={post.data.publishedAt.toISOString()}>
                {post.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              </time>
              <span class="opacity-50 mx-2">·</span>
              By {authorName}
            </p>
          </div>
        </div>
      </div>
    </header>

    {/* TL;DR answer capsule - for AI search engines */}
    <aside class="bg-bone-deep/30 text-primary border-y border-rule">
      <div class="max-w-[820px] mx-auto px-7 lg:px-0 py-12">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-sun-deep mb-4">
          The TL;DR
        </p>
        <p
          class="font-serif-quote italic text-primary text-[1.25rem] lg:text-[1.5rem] leading-[1.45] tracking-[-0.01em] text-balance"
          style="font-variation-settings: 'opsz' 36, 'SOFT' 60, 'WONK' 1;"
        >
          {post.data.tldr}
        </p>
      </div>
    </aside>

    {/* Body - bone bg, dark text */}
    <div class="bg-bone text-primary">
      <div class="max-w-[720px] mx-auto px-7 lg:px-0 py-20 lg:py-28">
        <div class="font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.75] text-primary/80 max-w-none journal-prose">
          <Content />
        </div>
      </div>
    </div>

    {/* Author bio */}
    <aside class="bg-bone text-primary border-t border-rule">
      <div class="max-w-[820px] mx-auto px-7 lg:px-0 py-14 flex flex-col sm:flex-row sm:items-start gap-5">
        <div
          class="shrink-0 size-16 rounded-full grid place-items-center bg-bone-deep/40"
          aria-hidden="true"
        >
          <span class="font-display text-[1.5rem] text-primary" style="font-variation-settings: 'opsz' 36;">
            {authorName.charAt(0)}
          </span>
        </div>
        <div>
          <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-primary/70 mb-2">
            Written by
          </p>
          <p
            class="font-display text-[1.25rem] leading-[1.2] font-normal"
            style="font-variation-settings: 'opsz' 36;"
          >
            {authorName}
          </p>
          <p class="font-body-md text-[1rem] leading-[1.6] text-primary/70 mt-2">
            {
              post.data.author === 'clint'
                ? 'Captain of Guiding Winds Unplug. Years on the water across the Caribbean chain.'
                : post.data.author === 'dodie'
                  ? 'Host of Guiding Winds Unplug. Galley lead, voyage planner, and the person who keeps the week unplugged.'
                  : 'Past guest of Guiding Winds Unplug, writing from their week aboard.'
            }
          </p>
        </div>
      </div>
    </aside>

    {/* CTA */}
    {relatedVoyageSlug && (
      <section class="bg-bone-deep/30 text-primary border-y border-rule">
        <div class="max-w-[820px] mx-auto px-7 lg:px-0 py-16 text-center">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-sun-deep mb-4">
            Where this trip happens
          </p>
          <h2
            class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
            style="font-size: clamp(1.625rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
          >
            See the voyage.
          </h2>
          <div class="mt-8">
            <a
              href={`/voyages/${relatedVoyageSlug}`}
              class="inline-flex items-center justify-center cursor-pointer bg-primary text-bone font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-9 py-[18px] hover:bg-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
            >
              Read the voyage
            </a>
          </div>
        </div>
      </section>
    )}

    {/* Newsletter */}
    <section class="bg-bone text-primary border-t border-rule">
      <div class="max-w-[820px] mx-auto px-7 lg:px-0 py-16">
        <NewsletterSignup variant="inline" heading="One or two pieces a month from the water." subtext="No urgency, no upsells. Unsubscribe with a click." />
      </div>
    </section>

    {/* Related posts */}
    {related.length > 0 && (
      <section class="bg-bone text-primary border-t border-rule">
        <div class="max-w-[1400px] mx-auto px-7 lg:px-14 py-16 lg:py-24">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-8">
            More from {categoryLabels[post.data.category]}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
            {
              related.map((p) => (
                <a
                  href={`/journal/${p.id}`}
                  class="group block focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
                >
                  <div
                    class="relative aspect-[16/10] mb-4 overflow-hidden bg-primary/5"
                    style={`background: ${categoryGradients[p.data.category]};`}
                  />
                  <h3 class="font-display text-[1.25rem] leading-[1.2] font-normal group-hover:text-accent transition-colors" style="font-variation-settings: 'opsz' 36;">
                    {p.data.title}
                  </h3>
                </a>
              ))
            }
          </div>
        </div>
      </section>
    )}
  </article>
</PostLayout>

<style is:global>
  /* Editorial type baseline for journal post content. Tailwind's prose
     plugin isn't installed; we set the necessary rules here so markdown
     renders the way the brand needs. */
  .journal-prose h2 {
    font-family: var(--font-fraunces);
    font-size: clamp(1.5rem, 2vw + 1rem, 2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-primary);
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
  }
  .journal-prose h3 {
    font-family: var(--font-fraunces);
    font-size: 1.375rem;
    line-height: 1.2;
    color: var(--color-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
    font-variation-settings: 'opsz' 36;
  }
  .journal-prose p { margin-bottom: 1.4em; }
  .journal-prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .journal-prose a:hover { color: var(--color-accent-hot); }
  .journal-prose ul, .journal-prose ol {
    margin: 1.4em 0 1.4em 0;
    padding-left: 1.5em;
  }
  .journal-prose ul { list-style: disc; }
  .journal-prose ol { list-style: decimal; }
  .journal-prose li { margin-bottom: 0.6em; }
  .journal-prose strong { color: var(--color-primary); font-weight: 600; }
  .journal-prose blockquote {
    font-family: var(--font-fraunces);
    font-size: 1.375rem;
    line-height: 1.4;
    font-style: italic;
    border-left: 2px solid var(--color-accent);
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: var(--color-primary);
    font-variation-settings: 'opsz' 24, 'SOFT' 50, 'WONK' 1;
  }
  .journal-prose hr {
    border: 0;
    border-top: 1px solid var(--color-rule);
    margin: 3rem 0;
  }
  .journal-prose code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: var(--color-bone-deep);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }
</style>
