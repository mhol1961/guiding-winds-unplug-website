---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import NewsletterSignup from '../../components/shared/NewsletterSignup.astro';

export async function getStaticPaths() {
  const posts = await getCollection('journal', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';
const postUrl = `${baseUrl}/journal/${post.id}`;

const categoryLabels: Record<string, string> = {
  guide: 'Guide',
  'field-notes': 'Field Notes',
  wellness: 'Wellness',
  'behind-the-boat': 'Behind the Boat',
};

const categoryGradients: Record<string, string> = {
  guide: 'linear-gradient(135deg, #1F1B17 0%, #0E3F47 100%)',
  'field-notes': 'linear-gradient(135deg, #0E3F47 0%, #161412 100%)',
  wellness: 'linear-gradient(135deg, #161412 0%, #1F1B17 100%)',
  'behind-the-boat': 'linear-gradient(135deg, #C92E1C 0%, #2A1F1A 100%)',
};

const authorName =
  post.data.author === 'dodie' ? 'Dodie Kendall' : post.data.author === 'clint' ? 'Clint Kendall' : 'Guest';

// Related posts — same category, exclude self, max 3.
const allPosts = await getCollection('journal', ({ data }) => !data.draft);
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);

const schemaGraph = [
  {
    '@type': 'BlogPosting',
    '@id': `${postUrl}#post`,
    headline: post.data.title,
    description: post.data.excerpt,
    image: post.data.heroImage
      ? post.data.heroImage.startsWith('http')
        ? post.data.heroImage
        : `${baseUrl}${post.data.heroImage}`
      : undefined,
    datePublished: post.data.publishedAt.toISOString(),
    dateModified: (post.data.updatedAt ?? post.data.publishedAt).toISOString(),
    author: { '@type': 'Person', name: authorName },
    publisher: {
      '@type': 'Organization',
      name: 'Guiding Winds Unplug',
      logo: { '@type': 'ImageObject', url: `${baseUrl}/og/logo.png` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
    keywords: post.data.tags.join(', '),
    articleSection: categoryLabels[post.data.category],
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Journal', item: `${baseUrl}/journal` },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
    ],
  },
];

// Optional CTA — link to related voyage if frontmatter specified one.
const relatedVoyageSlug = post.data.relatedVoyage;
---

<PostLayout
  title={post.data.seo.title}
  description={post.data.seo.description}
  publishDate={post.data.publishedAt.toISOString()}
  modifiedDate={post.data.updatedAt?.toISOString()}
  author={authorName}
  category={categoryLabels[post.data.category]}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  schema={schemaGraph}
>
  {/* Article hero */}
  <article>
    <header
      class="relative bg-primary text-ink border-b border-hairline"
      style={`background: ${categoryGradients[post.data.category]};`}
    >
      <div class="max-w-[820px] mx-auto px-7 lg:px-0 pt-24 lg:pt-32 pb-20 lg:pb-24">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-accent mb-6">
          {categoryLabels[post.data.category]}
        </p>
        <h1
          class="font-display text-ink leading-[1] tracking-[-0.025em] font-light text-balance"
          style="font-size: clamp(2rem, 4vw + 1rem, 3.75rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
        >
          {post.data.title}
        </h1>
        <p class="font-body-md text-[0.9375rem] text-ink/70 mt-8">
          <time datetime={post.data.publishedAt.toISOString()}>
            {post.data.publishedAt.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </time>{' '}
          · by {authorName}
        </p>
      </div>
    </header>

    {/* TL;DR answer capsule — for AI search engines */}
    <aside class="bg-bone text-primary border-t border-primary/10">
      <div class="max-w-[820px] mx-auto px-7 lg:px-0 py-10">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-3">
          TL;DR
        </p>
        <p
          class="font-serif-quote italic text-primary text-[1.25rem] leading-[1.5] tracking-[-0.01em]"
          style="font-variation-settings: 'opsz' 24, 'SOFT' 50, 'WONK' 1;"
        >
          {post.data.tldr}
        </p>
      </div>
    </aside>

    {/* Body */}
    <div class="bg-primary text-ink border-t border-hairline">
      <div class="max-w-[720px] mx-auto px-7 lg:px-0 py-20 lg:py-28">
        <div class="prose prose-invert font-body-lg text-[1.0625rem] leading-[1.75] text-ink-soft max-w-none journal-prose">
          <Content />
        </div>
      </div>
    </div>

    {/* Author bio */}
    <aside class="bg-primary text-ink border-t border-hairline">
      <div class="max-w-[820px] mx-auto px-7 lg:px-0 py-14 flex flex-col sm:flex-row sm:items-start gap-5">
        <div
          class="shrink-0 size-16 rounded-full grid place-items-center bg-bone/15 backdrop-blur-md"
          aria-hidden="true"
        >
          <span class="font-display text-[1.5rem] text-ink" style="font-variation-settings: 'opsz' 36;">
            {authorName.charAt(0)}
          </span>
        </div>
        <div>
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-ink-soft mb-2">
            Written by
          </p>
          <p
            class="font-h3 text-ink text-[1.25rem] leading-[1.2] font-medium"
            style="font-variation-settings: 'opsz' 36;"
          >
            {authorName}
          </p>
          <p class="font-body-md text-[0.9375rem] leading-[1.6] text-ink-soft mt-2">
            {
              post.data.author === 'clint'
                ? 'Captain of Guiding Winds Unplug. USCG Master 100-Ton. 20+ years on the water.'
                : post.data.author === 'dodie'
                  ? 'Host of Guiding Winds Unplug. Galley lead, voyage planner, and the person who decides when the Starlink goes off.'
                  : 'Past guest of Guiding Winds Unplug, writing from their week aboard.'
            }
          </p>
        </div>
      </div>
    </aside>

    {/* CTA */}
    {relatedVoyageSlug && (
      <section class="bg-bone text-primary border-t border-primary/10">
        <div class="max-w-[820px] mx-auto px-7 lg:px-0 py-16 text-center">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-primary/55 mb-4">
            Where this trip happens
          </p>
          <h2
            class="font-h2 text-primary leading-[1.05] tracking-[-0.02em] font-normal text-balance"
            style="font-size: clamp(1.5rem, 2.5vw + 1rem, 2rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
          >
            See the voyage.
          </h2>
          <div class="mt-8">
            <a
              href={`/voyages/${relatedVoyageSlug}`}
              class="inline-flex items-center justify-center cursor-pointer bg-primary text-ink font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
            >
              Read the voyage
            </a>
          </div>
        </div>
      </section>
    )}

    {/* Newsletter */}
    <section class="bg-primary text-ink border-t border-hairline">
      <div class="max-w-[820px] mx-auto px-7 lg:px-0 py-16">
        <NewsletterSignup variant="footer" heading="One or two pieces a month from the water." subtext="No urgency, no upsells. Unsubscribe with a click." />
      </div>
    </section>

    {/* Related posts */}
    {related.length > 0 && (
      <section class="bg-primary text-ink border-t border-hairline">
        <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-16 lg:py-20">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-8">
            More from {categoryLabels[post.data.category]}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
            {
              related.map((p) => (
                <a
                  href={`/journal/${p.id}`}
                  class="group block focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
                >
                  <div
                    class="aspect-[16/10] mb-4"
                    style={`background: ${categoryGradients[p.data.category]};`}
                  />
                  <h3 class="font-h3 text-ink text-[1.125rem] leading-[1.2] font-medium group-hover:text-accent transition-colors" style="font-variation-settings: 'opsz' 36;">
                    {p.data.title}
                  </h3>
                </a>
              ))
            }
          </div>
        </div>
      </section>
    )}
  </article>
</PostLayout>

<style is:global>
  /* Editorial type baseline for journal post content. Tailwind's prose
     plugin isn't installed; we set the necessary rules here so markdown
     renders the way the brand needs. */
  .journal-prose h2 {
    font-family: var(--font-fraunces);
    font-size: clamp(1.5rem, 2vw + 1rem, 2rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    margin-top: 3rem;
    margin-bottom: 1.25rem;
    font-weight: 400;
    font-variation-settings: 'opsz' 72;
  }
  .journal-prose h3 {
    font-family: var(--font-fraunces);
    font-size: 1.375rem;
    line-height: 1.2;
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 500;
    font-variation-settings: 'opsz' 36;
  }
  .journal-prose p { margin-bottom: 1.4em; }
  .journal-prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .journal-prose a:hover { color: var(--color-accent-hot); }
  .journal-prose ul, .journal-prose ol {
    margin: 1.4em 0 1.4em 0;
    padding-left: 1.5em;
  }
  .journal-prose ul { list-style: disc; }
  .journal-prose ol { list-style: decimal; }
  .journal-prose li { margin-bottom: 0.6em; }
  .journal-prose strong { color: var(--color-ink); font-weight: 600; }
  .journal-prose blockquote {
    font-family: var(--font-fraunces);
    font-size: 1.375rem;
    line-height: 1.4;
    font-style: italic;
    border-left: 2px solid var(--color-accent);
    padding-left: 1.5rem;
    margin: 2rem 0;
    color: var(--color-ink);
    font-variation-settings: 'opsz' 24, 'SOFT' 50, 'WONK' 1;
  }
  .journal-prose hr {
    border: 0;
    border-top: 1px solid var(--color-hairline);
    margin: 3rem 0;
  }
  .journal-prose code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.9em;
    background: var(--color-surface);
    padding: 0.15em 0.4em;
    border-radius: 2px;
  }
</style>
