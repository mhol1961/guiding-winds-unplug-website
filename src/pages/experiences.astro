---
// /experiences - stripped down per owner direction. The prior add-on
// content (spiritual retreat with Dodie, sport fishing with Clint, the
// "typical day" narrative, and the from-aboard gallery) was removed.
// Real content will be added back when it's ready.
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/shared/PageHero.astro';

const title = 'Optional experiences · Guiding Winds Unplug';
const description =
  'Optional experiences to shape a Guiding Winds voyage to your week. Book a quick call and we will talk through what fits.';

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';

const schemaGraph = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Experiences', item: `${baseUrl}/experiences` },
    ],
  },
];
---

<BaseLayout title={title} description={description} transparentNav schema={schemaGraph}>
  <PageHero
    eyebrow="Optional experiences"
    headlinePrefix="Two ways to shape"
    headlineEmphasis="a week aboard."
    headlineSuffix=""
    subline="Optional experiences can be layered onto any voyage. Book a quick call and we'll talk through what fits your week."
    heroImage="/img/stock/experiences/experiences-hero-ai.jpg"
    heroImageAlt="The teak aft deck of a catamaran at first light, the boat anchored alone in glassy turquoise water"
  />

  {/* Pre-footer CTA - teal-soft, matches the rest of the site's pattern */}
  <section class="bg-teal-soft text-primary py-24 sm:py-28 border-t border-hairline">
    <div class="max-w-[1100px] mx-auto px-7 lg:px-14 text-center">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-teal-shadow mb-5">
        Speak with us first
      </p>
      <h2
        class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance text-primary"
        style="font-size: clamp(2rem, 3.5vw + 1rem, 3rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
      >
        Add an experience
        <span class="italic font-normal" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
          when we talk.
        </span>
      </h2>
      <p class="font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.65] text-primary/75 max-w-2xl mx-auto mt-8 mb-10 text-balance">
        We speak with every guest before booking. Book a quick call and we'll walk you through the open weeks and talk through what fits your week.
      </p>
      <div class="flex justify-center">
        <a
          href="/inquire"
          class="group inline-flex items-center justify-center gap-3 cursor-pointer bg-primary text-ink font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-9 py-[18px] hover:bg-surface-warm transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
        >
          See available weeks and Book a quick call
          <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
