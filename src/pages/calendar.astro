---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = '2027 Sailing Calendar · Guiding Winds Unplug';
const description =
  'Fourteen weeks aboard, eight cabins each. Hold one for 72 hours, no payment required.';

const voyages = await getCollection('voyages');

interface CalendarRow {
  voyageSlug: string;
  voyageName: string;
  region: 'caribbean' | 'bahamas' | 'mediterranean';
  start: string;
  end: string;
  cabinsAvailable: number;
  price: number;
  heroImage: string;
}

const rows: CalendarRow[] = voyages
  .flatMap((v) =>
    v.data.availableWeeks.map((w) => ({
      voyageSlug: v.data.slug,
      voyageName: v.data.name,
      region: v.data.region,
      start: w.start,
      end: w.end,
      cabinsAvailable: w.cabinsAvailable,
      price: v.data.pricePerGuestUSD,
      heroImage: v.data.heroImage,
    })),
  )
  .sort((a, b) => a.start.localeCompare(b.start));

const totalWeeks = rows.length;
const totalCabins = rows.reduce((s, r) => s + r.cabinsAvailable, 0);

const regionLabel: Record<string, string> = {
  caribbean: 'Caribbean',
  bahamas: 'Bahamas',
  mediterranean: 'Mediterranean',
};

function formatWeek(start: string, end: string) {
  const s = new Date(`${start}T12:00:00Z`);
  const e = new Date(`${end}T12:00:00Z`);
  const fmt = (d: Date) =>
    d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
  return `${fmt(s)} – ${fmt(e)}, ${s.getUTCFullYear()}`;
}

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';
const schemaGraph = [
  { '@type': 'EventSeries', name: '2027 Sailing Calendar — Guiding Winds Unplug', description },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Calendar', item: `${baseUrl}/calendar` },
    ],
  },
];
---

<BaseLayout title={title} description={description} schema={schemaGraph}>
  {/* Hero — bone */}
  <section class="bg-bone text-primary pt-32 lg:pt-40 pb-16 lg:pb-20 border-b border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-6">
        2027 Calendar
      </p>
      <h1
        class="font-display font-light leading-[0.95] tracking-[-0.03em] text-balance max-w-4xl"
        style="font-size: clamp(2.5rem, 6vw + 1rem, 5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
      >
        Fourteen weeks.
        <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;">
          Eight cabins each.
        </span>
      </h1>
      <p class="font-body-lg text-[1.0625rem] lg:text-[1.1875rem] leading-[1.6] text-primary/70 mt-8 max-w-3xl">
        Hold one for 72 hours, no payment required. Caribbean January through
        March. Bahamas April and May. Mediterranean June through October.
      </p>
      <p class="font-body-md text-[1rem] text-primary/55 mt-6">
        <span class="font-display text-[1.5rem] mr-2" style="font-variation-settings: 'opsz' 36;">{totalCabins}</span>
        cabins available right now · {totalWeeks} weeks total
      </p>
    </div>
  </section>

  {/* Region filter — sticky */}
  <section class="bg-bone text-primary sticky top-20 z-10 backdrop-blur-md bg-bone/95 border-b border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14 py-5 flex flex-wrap items-center gap-x-7 gap-y-3">
      <span class="font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold text-primary/55">
        Filter
      </span>
      {
        ['all', 'caribbean', 'bahamas', 'mediterranean'].map((r) => (
          <button
            type="button"
            data-region-filter={r}
            class:list={[
              'cursor-pointer font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold transition-colors pb-1.5 border-b',
              r === 'all' ? 'text-primary border-accent' : 'text-primary/55 border-transparent hover:text-primary',
            ]}
            aria-pressed={r === 'all'}
          >
            {r === 'all' ? 'All weeks' : regionLabel[r]}
          </button>
        ))
      }
    </div>
  </section>

  {/* Calendar — image-led row per week */}
  <section class="bg-bone text-primary pt-12 pb-24 lg:pb-32">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div id="calendar-list" class="space-y-4 lg:space-y-5">
        {
          rows.map((row) => {
            const soldOut = row.cabinsAvailable === 0;
            return (
              <article
                data-region={row.region}
                class="grid grid-cols-12 gap-4 lg:gap-6 items-center py-5 border-b border-rule group"
              >
                <a href={`/voyages/${row.voyageSlug}`} class="col-span-3 sm:col-span-2 block aspect-[16/10] overflow-hidden bg-primary/5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3">
                  <img src={row.heroImage} alt={row.voyageName} loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]" />
                </a>
                <div class="col-span-9 sm:col-span-3">
                  <p class="font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold text-primary/55">
                    {regionLabel[row.region]}
                  </p>
                  <p class="font-display text-[1.25rem] lg:text-[1.5rem] leading-[1.1] text-primary mt-1 group-hover:text-accent transition-colors" style="font-variation-settings: 'opsz' 36;">
                    <a href={`/voyages/${row.voyageSlug}`}>{row.voyageName}</a>
                  </p>
                </div>
                <p class="col-span-7 sm:col-span-3 font-body-md text-[1rem] text-primary/75 tabular-nums">
                  {formatWeek(row.start, row.end)}
                </p>
                <p class="hidden sm:block sm:col-span-1 font-body-md text-[1rem] text-primary/75 tabular-nums">
                  ${row.price.toLocaleString()}
                </p>
                <p class="col-span-2 sm:col-span-1 text-right font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold tabular-nums">
                  <span class={soldOut ? 'text-primary/40' : row.cabinsAvailable <= 2 ? 'text-accent' : 'text-primary/65'}>
                    {soldOut ? 'Sold out' : `${row.cabinsAvailable} cabins`}
                  </span>
                </p>
                <div class="col-span-3 sm:col-span-2 text-right">
                  {soldOut ? (
                    <a href={`/inquire?voyage=${row.voyageSlug}`} class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary/55 hover:text-accent transition-colors">
                      Join waitlist
                    </a>
                  ) : (
                    <a
                      href={`/inquire?voyage=${row.voyageSlug}`}
                      class="inline-flex items-center gap-2 cursor-pointer bg-primary text-bone font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold px-4 py-2.5 hover:bg-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
                    >
                      Hold
                    </a>
                  )}
                </div>
              </article>
            );
          })
        }
      </div>

      <p id="empty-state" class="hidden text-center py-20 font-body-lg text-primary/55">
        No weeks match this filter.
      </p>
    </div>
  </section>

  {/* Fallback CTA */}
  <section class="bg-bone-deep/30 text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[820px] mx-auto px-7 lg:px-0 text-center">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-5">
        Don't see the right week?
      </p>
      <h2
        class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
        style="font-size: clamp(1.875rem, 3.5vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
      >
        Tell us what you're looking for.
      </h2>
      <p class="font-body-md text-[1rem] text-primary/65 mt-6 max-w-xl mx-auto">
        We sometimes open a private-charter week based on group interest, and
        we're happy to hold a week from the public calendar while you align
        with your group.
      </p>
      <div class="mt-10">
        <a
          href="/inquire"
          class="inline-flex items-center justify-center cursor-pointer bg-primary text-bone font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-9 py-[18px] hover:bg-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
        >
          Send an Inquiry
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-region-filter]');
  const rows = document.querySelectorAll<HTMLElement>('article[data-region]');
  const empty = document.getElementById('empty-state');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.regionFilter ?? 'all';
      buttons.forEach((b) => {
        const active = b === btn;
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
        if (active) {
          b.classList.remove('text-primary/55', 'border-transparent');
          b.classList.add('text-primary', 'border-accent');
        } else {
          b.classList.remove('text-primary', 'border-accent');
          b.classList.add('text-primary/55', 'border-transparent');
        }
      });
      let visibleCount = 0;
      rows.forEach((row) => {
        const matches = target === 'all' || row.dataset.region === target;
        row.classList.toggle('hidden', !matches);
        if (matches) visibleCount++;
      });
      if (empty) empty.classList.toggle('hidden', visibleCount > 0);
    });
  });
</script>
