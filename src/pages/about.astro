---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionInterrupt from '../components/shared/SectionInterrupt.astro';
import { ShieldCheck, Anchor, Award, FileCheck2, Sun } from 'lucide-react';

const title = 'Meet Clint & Dodie Kendall · Captains of Guiding Winds Unplug';
const description =
  'A husband-and-wife crew running all-inclusive catamaran voyages from the British Virgin Islands. Clint at the helm, born in Miami Beach and raised in the Florida Keys. Dodie running the galley and the guest experience.';

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';

const schemaGraph = [
  {
    '@type': 'Person',
    '@id': `${baseUrl}/about#clint`,
    name: 'Clint Kendall',
    jobTitle: 'Captain',
    worksFor: { '@type': 'Organization', name: 'Guiding Winds Unplug' },
    birthPlace: 'Miami Beach, Florida',
    knowsAbout: ['Catamaran sailing', 'Caribbean navigation', 'Long-line fishing', 'Florida Keys waters'],
  },
  {
    '@type': 'Person',
    '@id': `${baseUrl}/about#dodie`,
    name: 'Dodie Kendall',
    jobTitle: 'Host & Galley Lead',
    worksFor: { '@type': 'Organization', name: 'Guiding Winds Unplug' },
    birthPlace: 'Fort Lauderdale, Florida',
    knowsAbout: ['Galley provisioning', 'Wellness hosting', 'Guest experience'],
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Our Story', item: `${baseUrl}/about` },
    ],
  },
];

// Credentials block — kept intentionally generic. Specific cert names,
// ticket levels, insurance providers, and renewal cadences were removed
// because they were placeholder copy from the prior pass and would be
// false claims about real people if shipped. Replace with verified
// specifics before launch; until then this block describes the kind
// of coverage in place without inventing details.
const credentials = [
  { Icon: ShieldCheck, label: 'USCG-licensed captain · documentation on request' },
  { Icon: FileCheck2, label: 'Current BVI cruising and charter permits' },
  { Icon: Award, label: 'Charter liability insurance in force' },
  { Icon: Sun, label: 'Annual safety-equipment certification — life raft, EPIRB, AED' },
  { Icon: Anchor, label: 'Years of working Florida Keys and Caribbean waters' },
];
---

<BaseLayout title={title} description={description} transparentNav schema={schemaGraph}>
  {/* Image hero — Clint & Dodie on the foredeck at sunset.
      object-[center_25%] biases the crop UP so neither captain's head
      gets clipped at hero aspect ratios. Overlay rebuilt as a 3-layer
      stack (matching SectionInterrupt photo variant) so the eyebrow up
      top AND the headline at the bottom both clear AA against the
      sunset photo. */}
  <section class="relative bg-primary text-ink overflow-hidden min-h-[88dvh] flex flex-col">
    <img
      src="/img/source/people/clint-dodie-foredeck-portrait-sunset-01.jpg"
      alt="Clint and Dodie Kendall on the foredeck of their catamaran at sunset"
      class="absolute inset-0 w-full h-full object-cover object-[center_25%]"
      fetchpriority="high"
      decoding="async"
    />
    {/* Base vertical darken */}
    <div class="absolute inset-0 bg-gradient-to-b from-primary/55 via-primary/30 to-primary/95" aria-hidden="true"></div>
    {/* Top band — guarantees AA for the eyebrow over any sky region */}
    <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-primary/70 to-transparent" aria-hidden="true"></div>
    {/* Bottom band — guarantees AA for the headline column */}
    <div class="absolute inset-x-0 bottom-0 h-2/5 bg-gradient-to-t from-primary/85 to-transparent" aria-hidden="true"></div>
    <div class="relative z-10 min-h-[88dvh] flex flex-col">
      <div class="flex-1 flex items-end pb-16 lg:pb-24 px-7 lg:px-14 pt-32">
        <div class="max-w-[1400px] w-full mx-auto">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.75rem] font-semibold text-bone mb-6">
            Our story · A husband-and-wife crew
          </p>
          <h1
            class="font-display text-ink font-light leading-[0.95] tracking-[-0.03em] max-w-5xl text-pretty"
            style="font-size: clamp(2.5rem, 6vw + 1rem, 5.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
          >
            Two captains.
            <span class="block italic mt-2" style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;">
              One slow life.
            </span>
          </h1>
        </div>
      </div>
    </div>
  </section>

  {/* Clint — left image, right text */}
  <section class="bg-bone text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-6">
          {/* Clint portrait — the original /img/source/people/clint-peace-sunset-portico-01.jpg
              was actually a photo of the front of the boat, not Clint. New
              real photo is landscape (~1.87:1) so the container is
              aspect-[3/2] with object-cover centered — minimal side crop. */}
          <figure class="relative aspect-[3/2] overflow-hidden bg-primary/5">
            <img
              src="/img/source/people/clint-kendall-pier-portrait.jpg"
              alt="Clint Kendall on a pier in the British Virgin Islands, white yacht moored in the bay behind him"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover object-center"
            />
          </figure>
        </div>
        <div class="lg:col-span-6">
          <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-sun-deep mb-5">
            The captain
          </p>
          <h2
            class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
            style="font-size: clamp(2rem, 3.5vw + 1rem, 3rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
          >
            Clint Kendall.
          </h2>
          <div class="mt-8 space-y-5 font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.7] text-primary/75 text-balance">
            <p>
              Born in Miami Beach, raised in the Florida Keys — the kind
              of place where you know the channel markers before you know
              your address. Clint spent years as a long-liner fisherman
              before he ever ran a charter, and the salt-life knowledge
              shows up in everything from how he reads weather to where
              he finds a quiet anchorage when the day-charter fleet is on
              the chain.
            </p>
            <p>
              His reputation in the Keys was simple: catch fish, bring
              everyone home, and don't make it complicated. He runs the
              boat the same way.
            </p>
            <p>
              The route of every voyage is built around what the water is
              actually doing that week, not what a brochure laid out a
              year ago.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Interrupt A1 — teal break between Clint and Dodie sections */}
  <SectionInterrupt
    variant="teal"
    eyebrow="The crew"
    headline="Two people."
    headlineItalic="One boat."
    body="Clint reads the weather and the chain. Dodie reads the guests and the galley. The week works because neither of us is doing the other's job."
  />

  {/* Dodie — right image, left text (alternating). bg-paper to break the
      bone wall between the Clint section and the teal interrupt. */}
  <section class="bg-paper text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-6 order-2 lg:order-1">
          <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-sun-deep mb-5">
            The host
          </p>
          <h2
            class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
            style="font-size: clamp(2rem, 3.5vw + 1rem, 3rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
          >
            Dodie Kendall.
          </h2>
          <div class="mt-8 space-y-5 font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.7] text-primary/75 text-balance">
            <p>
              Born in Fort Lauderdale, raised in Pompano Beach. Dodie has
              spent most of her life within walking distance of the water
              and most of her career helping people reconnect with
              themselves — work she now does on the boat, where the
              schedule is the tide and the only obligation is to be where
              you are.
            </p>
            <p>
              Most charter operations split cooking and hosting between
              two people. Dodie does both because she likes the
              through-line — the same person who knows what's on the menu
              also knows what kind of week each guest is having, and can
              shift the third night's dinner accordingly.
            </p>
            <p>
              If you want the morning practice on deck, she leads it. If
              you want a quiet hour with coffee, she'll set you up with
              coffee and disappear.
            </p>
          </div>
        </div>
        <div class="lg:col-span-6 order-1 lg:order-2">
          {/* Dodie portrait — was a cropped Clint+Dodie selfie, swapped for
              a real solo portrait of her on the beach (1122x1402, fits
              aspect-[4/5] cleanly). */}
          <figure class="relative aspect-[4/5] overflow-hidden bg-primary/5">
            <img
              src="/img/source/people/dodie-kendall-beach-portrait.jpg"
              alt="Dodie Kendall smiling on the beach, the Caribbean surf behind her"
              loading="lazy"
              decoding="async"
              class="absolute inset-0 w-full h-full object-cover object-center"
            />
          </figure>
        </div>
      </div>
    </div>
  </section>

  {/* Why Guiding Winds exists — narrow centered editorial */}
  <section class="bg-bone-deep/30 text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[820px] mx-auto px-7 lg:px-0 text-center">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-6">
        Why Guiding Winds exists
      </p>
      <h2
        class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
        style="font-size: clamp(1.875rem, 3.5vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
      >
        The market had room for one boat — run
        <span class="italic block" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
          by its crew.
        </span>
      </h2>
      <div class="mt-10 space-y-6 font-body-lg text-[1.0625rem] leading-[1.75] text-primary/80 text-left text-balance">
        <p>
          The Caribbean charter market mostly works one of two ways. Either
          you bareboat — captain yourself, plan the route, do the
          provisioning, fix what breaks — or you book through a fleet
          operator who hands you a different captain each week and a menu
          written by corporate. The first requires a sailing résumé. The
          second requires forgetting you ever wanted a real conversation
          with the captain.
        </p>
        <p>
          We wanted to run something narrower than either. One boat. Two
          captains. Fourteen weeks a year. The same people on board every
          week so guests get to know us by name and we get to know what
          they're celebrating. It's a smaller business by design.
        </p>
      </div>
    </div>
  </section>

  {/* Boat preview linking to /aboard. Dark bg-surface-warm so the
      bright turquoise of the Seedance establishing video pops against
      the panel rather than competing with another cream surface. */}
  <section class="bg-surface-warm text-ink py-24 sm:py-32 border-t border-hairline">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-sun mb-5">
            The boat
          </p>
          <h2
            class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
            style="font-size: clamp(1.875rem, 3.5vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
          >
            A 50-foot catamaran, chosen for
            <span class="italic block" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
              the cabin.
            </span>
          </h2>
          <p class="mt-7 font-body-lg text-[1.0625rem] leading-[1.7] text-ink/80">
            Eight ensuite queens. Full galley. Salon that seats twelve for
            dinner. We considered every cat from 45 to 60 feet and picked
            the 50 because it was the smallest boat that let every cabin
            sleep adults comfortably.
          </p>
          <a
            href="/aboard"
            class="group inline-flex items-center gap-3 mt-9 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold text-ink border-b-2 border-sun pb-1 hover:text-sun transition-colors"
          >
            See what's aboard
            <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
        {/* Establishing video — Seedance v1 Pro render, 5s 1080p 16:9,
            silent autoplay loop. Poster + bg-primary fallback guarantee
            the section never collapses if the video fails to load. */}
        <figure
          id="film"
          class="relative aspect-[3/2] overflow-hidden bg-primary"
        >
          <video
            class="absolute inset-0 w-full h-full object-cover"
            src="/media/about/boat-lagoon50-establishing.mp4"
            poster="/img/source/destinations/catamaran-anchored-green-headland-01.jpg"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            aria-label="A 50-foot Lagoon catamaran at anchor in turquoise water at golden hour"
          ></video>
          <span class="absolute top-5 right-5 inline-flex items-center rounded-pill bg-bone/85 backdrop-blur-md px-3 py-1.5 font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold text-primary">
            Aboard · establishing reel
          </span>
        </figure>
      </div>
    </div>
  </section>

  {/* Interrupt A2 — full-bleed photo break before credentials.
      Iteration 3 on this slot. The original near-black moonlit shot
      and then Dodie's IG harbor-sunset-moon both read as murky
      silhouettes at full-bleed (Mark: "I cannot make out what this
      image is"). Now using a fal.ai FLUX render of a single white
      catamaran at anchor at blue hour with warm interior lights, a
      visible full moon, and a peach horizon — clearly recognizable
      on first look while still tranquil and "night." */}
  <SectionInterrupt
    variant="photo"
    image="/img/stock/destinations/quiet-anchorage-blue-hour-ai.jpg"
    imageAlt="A single white catamaran at anchor alone in a sheltered cove at blue hour — warm interior lights glow from the salon, a full moon hangs upper right, the horizon still carries pink and peach from the sunset"
    eyebrow="On any given night"
    headline="Quiet anchorages."
    headlineItalic="No crowd to be part of."
    photoAlign="left"
  />

  {/* Credentials & safety — bg-paper to alternate against the surrounding
      sections (dark surface-warm boat panel above, light teal CTA below). */}
  <section class="bg-paper text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-10">
        Credentials & safety
      </p>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-6">
        {
          credentials.map(({ Icon, label }) => (
            <li class="flex items-start gap-4 border-b border-rule pb-5">
              <Icon className="size-5 text-sun shrink-0 mt-1" strokeWidth={1.5} />
              <span class="font-body-md text-[1rem] leading-[1.55] text-primary/80">
                {label}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* CTA — light teal pre-footer (Mark's requirement: the section
      immediately above the dark footer must be light, not another dark
      panel). bg-teal-soft reads as marine-adjacent without going as
      heavy as bg-teal-shadow. */}
  <section class="bg-teal-soft text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[720px] mx-auto px-7 lg:px-0 text-center">
      <span class="block w-12 h-px bg-sun mx-auto mb-10" aria-hidden="true"></span>
      <h2
        class="font-display font-light leading-[1.0] tracking-[-0.025em] text-balance"
        style="font-size: clamp(2rem, 5vw + 1rem, 4rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
      >
        Come sail
        <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;">with us.</span>
      </h2>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
        <a
          href="/calendar"
          class="inline-flex items-center justify-center cursor-pointer bg-primary text-bone font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-9 py-[18px] hover:bg-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
        >
          See Available Weeks
        </a>
        <a
          href="/inquire"
          class="group inline-flex items-center gap-3 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold text-primary border-b border-primary/40 pb-1 hover:text-accent hover:border-accent transition-colors"
        >
          Or send an inquiry
          <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
