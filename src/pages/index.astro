---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Guiding Winds Unplug — Off-Grid Catamaran Voyages';
const description =
  'All-inclusive wellness catamaran voyages for 8–12 guests in the British Virgin Islands, Bahamas, and Mediterranean. From $3,550 per guest, per week.';
---

<BaseLayout title={title} description={description}>
  <main class="min-h-[100dvh] grid place-items-center bg-primary text-ink px-6">
    <div class="max-w-2xl text-center">
      <p
        class="uppercase tracking-[0.28em] text-[0.6875rem] text-ink-soft mb-8 font-semibold"
      >
        Phase 1 — Foundation
      </p>
      <h1
        class="font-display text-display leading-display tracking-display font-light text-balance"
        style="font-size: clamp(2.75rem, 7vw + 1rem, 5.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
      >
        The boat is in <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 1;">the slip.</span>
      </h1>
      <p class="mt-8 text-ink-soft text-lg leading-relaxed max-w-[52ch] mx-auto">
        Scaffold complete. Astro 6, Tailwind v4, the Cloudflare adapter and the
        DESIGN.md token bridge are wired. The home page lives here next.
      </p>
      <div class="mt-12 inline-flex items-center gap-3">
        <span class="block w-2 h-2 rounded-full bg-accent" aria-hidden="true"></span>
        <span class="uppercase tracking-[0.28em] text-[0.6875rem] text-ink-soft font-semibold">
          Ready for Phase 2
        </span>
      </div>
    </div>
  </main>
</BaseLayout>
