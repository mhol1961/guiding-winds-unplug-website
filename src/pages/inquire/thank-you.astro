---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Inquiry received · Guiding Winds Unplug';
const description = 'Thanks — Dodie or Clint will reply within 24 hours.';
---

<BaseLayout title={title} description={description} noindex>
  <section class="bg-bone text-primary min-h-[60dvh] grid place-items-center">
    <div class="max-w-2xl px-7 lg:px-0 text-center py-20">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-accent mb-6">
        Inquiry received
      </p>
      <h1
        class="font-display text-primary leading-[1] tracking-[-0.025em] font-light text-balance"
        style="font-size: clamp(2rem, 4vw + 1rem, 3.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
      >
        Thanks — we will be in touch within
        <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 1;">twenty-four hours.</span>
      </h1>
      <p class="font-body-lg text-[1.0625rem] leading-[1.65] text-primary/65 mt-8 max-w-xl mx-auto">
        Either Dodie or Clint will reply with availability for your preferred
        week and the next steps. While you wait — here's a 3-minute look at a
        day aboard.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/about#film"
          class="inline-flex items-center justify-center cursor-pointer bg-accent text-primary font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-accent-hot transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
        >
          Watch the Film
        </a>
        <a
          href="/journal"
          class="inline-flex items-center justify-center cursor-pointer bg-transparent text-primary border border-ink/30 font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-ink hover:text-primary transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
        >
          Read the Journal
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
