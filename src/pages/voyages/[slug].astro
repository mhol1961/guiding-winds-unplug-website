---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import VoyageHero from '../../components/voyage/VoyageHero.astro';
import PricingCard from '../../components/voyage/PricingCard.astro';
import Timeline from '../../components/voyage/Timeline.astro';
import Gallery from '../../components/voyage/Gallery.astro';
import VoyageFaq from '../../components/voyage/VoyageFaq.astro';
import SectionInterrupt from '../../components/shared/SectionInterrupt.astro';
import { Check, X } from 'lucide-react';

export async function getStaticPaths() {
  const voyages = await getCollection('voyages');
  return voyages.map((voyage) => ({
    params: { slug: voyage.data.slug },
    props: { voyage },
  }));
}

const { voyage } = Astro.props;
const { Content } = await render(voyage);

const regionLabel: Record<string, string> = {
  caribbean: 'Caribbean',
  bahamas: 'Bahamas',
  mediterranean: 'Mediterranean',
};

// Per-voyage fallback gradients (ADR-011: design must hold without photos).
// Top stops use a lifted, saturated destination color so the page reads
// "Caribbean" / "Bahamas" / etc. at first glance instead of a black slab.
const fallbackGradients: Record<string, string> = {
  'british-virgin-islands': 'linear-gradient(165deg, #1E7A8C 0%, #0E3F47 45%, #0A0A0A 100%)',
  bahamas: 'linear-gradient(165deg, #E58A4D 0%, #C92E1C 35%, #1F1B17 100%)',
  italy: 'linear-gradient(165deg, #C9633C 0%, #5F2F1A 45%, #0A0A0A 100%)',
  greece: 'linear-gradient(165deg, #4A8FA3 0%, #0E3F47 45%, #0A0A0A 100%)',
  croatia: 'linear-gradient(165deg, #4D7A78 0%, #1F1B17 50%, #0A0A0A 100%)',
};

const emphasis: Record<string, string> = {
  'british-virgin-islands': 'One catamaran, up to 12 guests, a week off the grid.',
  bahamas: 'Pink sand, shallow water, the slow Caribbean.',
  italy: 'Capri at sunrise, dinners that ruin you for hotels.',
  greece: 'The Cyclades at the pace they were meant to be sailed.',
  croatia: 'Split to Dubrovnik, the long way around.',
};

// Schema graph for the page — TouristTrip + Offer per available week +
// FAQPage from frontmatter FAQ + BreadcrumbList.
const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';
const pageUrl = `${baseUrl}/voyages/${voyage.data.slug}`;

const touristTrip = {
  '@type': 'TouristTrip',
  '@id': `${pageUrl}#trip`,
  name: voyage.data.name,
  description: voyage.data.seo.description,
  image: voyage.data.heroImage.startsWith('http')
    ? voyage.data.heroImage
    : `${baseUrl}${voyage.data.heroImage}`,
  touristType: ['Wellness traveler', 'Adventure traveler', 'Small-group traveler'],
  itinerary: voyage.data.itinerary.map((day) => ({
    '@type': 'Place',
    name: day.title,
    description: day.body,
  })),
  offers: voyage.data.availableWeeks.map((week) => ({
    '@type': 'Offer',
    price: voyage.data.pricePerGuestUSD,
    priceCurrency: 'USD',
    availability:
      week.cabinsAvailable > 0
        ? 'https://schema.org/InStock'
        : 'https://schema.org/SoldOut',
    validFrom: week.start,
    validThrough: week.end,
    inventoryLevel: { '@type': 'QuantitativeValue', value: week.cabinsAvailable },
  })),
  provider: { '@id': `${baseUrl}/#org` },
};

const faqSchema = voyage.data.faq.length
  ? {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: voyage.data.faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    }
  : null;

const breadcrumbs = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Voyages', item: `${baseUrl}/voyages` },
    { '@type': 'ListItem', position: 3, name: voyage.data.name, item: pageUrl },
  ],
};

// Per-voyage reviews → Review + AggregateRating schema (Codex review crit #3).
const allReviews = await getCollection('reviews');
const voyageReviews = allReviews.filter((r) => r.data.voyage === voyage.data.slug);
const reviewSchemas = voyageReviews.map((r) => ({
  '@type': 'Review',
  itemReviewed: { '@id': `${pageUrl}#trip` },
  reviewRating: {
    '@type': 'Rating',
    ratingValue: r.data.rating,
    bestRating: 5,
  },
  author: { '@type': 'Person', name: r.data.author },
  reviewBody: r.data.quote,
  datePublished: r.data.date.toISOString().split('T')[0],
}));
// Only surface AggregateRating when we have meaningful sample size. Single-
// digit reviewCount on a perfect 5.0 reads as a spam signal to Google's
// product-results algorithm (per Codex review).
const aggregateRating =
  voyageReviews.length >= 3
    ? {
        '@type': 'AggregateRating',
        itemReviewed: { '@id': `${pageUrl}#trip` },
        ratingValue:
          voyageReviews.reduce((s, r) => s + r.data.rating, 0) / voyageReviews.length,
        bestRating: 5,
        reviewCount: voyageReviews.length,
      }
    : null;

const schemaGraph: object[] = [touristTrip, breadcrumbs];
if (faqSchema) schemaGraph.push(faqSchema);
for (const r of reviewSchemas) schemaGraph.push(r);
if (aggregateRating) schemaGraph.push(aggregateRating);

// Cross-link to sibling voyages.
const allVoyages = await getCollection('voyages');
const siblings = allVoyages.filter((v) => v.data.slug !== voyage.data.slug).slice(0, 2);

// ── Mid-page interrupt copy (Section S1 audit fix) ────────────────────────
// The voyage detail page used to be 6,000-7,000px of unbroken cream — one
// giant wall of tan. These three interrupt sections break the stretch at
// ~1,500-2,000px intervals so the eye gets rhythm.

// Teal mood-setter, lands between Overview and Timeline.
const tealEyebrow: Record<string, string> = {
  'british-virgin-islands': 'The water',
  bahamas: 'The water',
  italy: 'The coast',
  greece: 'The Aegean',
  croatia: 'The Adriatic',
};
const tealHeadline: Record<string, { lead: string; italic: string }> = {
  'british-virgin-islands': {
    lead: 'Glass water at sunrise.',
    italic: 'Anchorages day-trippers never reach.',
  },
  bahamas: {
    lead: 'Pink sand, shallow water,',
    italic: 'the slow Caribbean.',
  },
  italy: {
    lead: 'Capri at sunrise.',
    italic: 'Anchorages that ruin you for hotels.',
  },
  greece: {
    lead: 'The Cyclades',
    italic: 'at the pace they were meant to be sailed.',
  },
  croatia: {
    lead: 'Stone villages on cliffs.',
    italic: 'Adriatic water clear to twenty meters.',
  },
};
const tealCopy = tealHeadline[voyage.data.slug] ?? {
  lead: voyage.data.shortDescription,
  italic: '',
};

// Stat interrupt, lands between FAQ and cross-link siblings.
const weekCount = voyage.data.availableWeeks.length;
const statCopyByRegion: Record<string, { headline: string; italic: string; body: string }> = {
  caribbean: {
    headline: `${weekCount} weeks open`,
    italic: 'Multiple weeks available — see the calendar',
    body: 'A limited run of weeks. When they\'re gone they\'re gone — we don\'t add capacity or stretch the run.',
  },
  bahamas: {
    headline: `${weekCount} weeks open`,
    italic: 'Multiple weeks available — see the calendar',
    body: 'A short run of weeks before we move the boat to the Mediterranean. Limited and not repeated.',
  },
  mediterranean: {
    headline: `${weekCount} weeks open`,
    italic: 'Multiple weeks available — see the calendar',
    body: 'We sail every week we\'re open, then the boat heads back across the Atlantic. A limited run.',
  },
};
const statCopy = statCopyByRegion[voyage.data.region];

// Quote interrupt, lands between Timeline and Gallery. Hidden if no review
// for this voyage exists.
const voyageReviewForInterrupt = voyageReviews[0] ?? null;
---

<BaseLayout
  title={voyage.data.seo.title}
  description={voyage.data.seo.description}
  transparentNav
  schema={schemaGraph}
>
  <VoyageHero
    region={regionLabel[voyage.data.region]}
    name={voyage.data.name}
    heroEyebrow={voyage.data.heroEyebrow}
    heroImage={voyage.data.heroImage}
    heroImageAlt={voyage.data.heroImageAlt}
    emphasis={emphasis[voyage.data.slug] ?? 'Seven nights off the grid.'}
    pricePerGuestUSD={voyage.data.pricePerGuestUSD}
    nights={voyage.data.nights}
    nightsLabel={voyage.data.nightsLabel}
    anchorages={voyage.data.itinerary.length}
  />

  {/* Overview + sticky PricingCard — bone bg, dark text */}
  <section class="bg-bone text-primary border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14 py-20 sm:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-8">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-5">
            The voyage
          </p>
          <h2
            class="font-display font-light leading-[1.1] tracking-[-0.025em] text-balance"
            style="font-size: clamp(1.875rem, 3vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
          >
            {voyage.data.shortDescription}
          </h2>

          <div class="mt-12 font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.7] text-primary/80 max-w-[68ch] journal-prose">
            <Content />
          </div>

          {/* Inclusions / Exclusions split */}
          <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-10 border-t border-rule pt-12">
            <div>
              <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-primary/70 mb-6">
                In the price
              </p>
              <ul class="space-y-3.5">
                {
                  voyage.data.inclusions.map((item) => (
                    <li class="flex items-start gap-3 font-body-md text-[1rem] text-primary/80">
                      <Check className="size-4 text-sun shrink-0 mt-1" strokeWidth={2} />
                      {item}
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-primary/70 mb-6">
                Not included
              </p>
              <ul class="space-y-3.5">
                {
                  voyage.data.exclusions.map((item) => (
                    <li class="flex items-start gap-3 font-body-md text-[1rem] text-primary/70">
                      <X className="size-4 text-primary/40 shrink-0 mt-1" strokeWidth={2} />
                      {item}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <div class="lg:col-span-4">
          <PricingCard
            pricePerGuestUSD={voyage.data.pricePerGuestUSD}
            availableWeeks={voyage.data.availableWeeks}
            voyageName={voyage.data.name}
            voyageSlug={voyage.data.slug}
          />
        </div>
      </div>
    </div>
  </section>

  {/* Interrupt 1 (teal) — mood-setter, breaks the bone after Overview */}
  <SectionInterrupt
    variant="teal"
    eyebrow={tealEyebrow[voyage.data.slug]}
    headline={tealCopy.lead}
    headlineItalic={tealCopy.italic}
  />

  <Timeline itinerary={voyage.data.itinerary} />

  {/* Interrupt 2 (quote) — full-bleed photo + guest review after Timeline.
      Hidden if no review exists for this voyage. */}
  {voyageReviewForInterrupt && (
    <SectionInterrupt
      variant="quote"
      eyebrow={`From the logbook · ${regionLabel[voyage.data.region]}`}
      headline={voyageReviewForInterrupt.data.quote}
      image={voyage.data.heroImage}
      imageAlt={voyage.data.heroImageAlt}
      attribution={`${voyageReviewForInterrupt.data.author} · ${voyageReviewForInterrupt.data.location} · ${voyage.data.name}`}
      ctaLabel="See available weeks"
      ctaHref="/calendar"
    />
  )}

  <Gallery images={voyage.data.galleryImages} fallbackGradient="" />
  {voyage.data.faq.length > 0 && <VoyageFaq faq={voyage.data.faq} />}

  {/* Interrupt 3 (stat) — dark scarcity / availability window after FAQ */}
  {statCopy && (
    <SectionInterrupt
      variant="stat"
      eyebrow="Availability"
      headline={statCopy.headline}
      headlineItalic={statCopy.italic}
      body={statCopy.body}
      ctaLabel="Hold a cabin"
      ctaHref="/inquire"
    />
  )}

  {/* Cross-link siblings — image-led portrait cards on bone */}
  <section class="bg-bone text-primary border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14 py-20 sm:py-24">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-10">
        Or see another voyage
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8">
        {
          siblings.map((sibling) => (
            <a
              href={`/voyages/${sibling.data.slug}`}
              class="group flex flex-col focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
            >
              <div class="relative aspect-[16/10] overflow-hidden mb-5 bg-primary/5">
                <img
                  src={sibling.data.heroImage}
                  alt={sibling.data.heroImageAlt}
                  loading="lazy"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
                />
                <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-primary/40 to-transparent pointer-events-none" aria-hidden="true"></div>
                <span class="absolute top-4 left-4 font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold text-bone bg-primary/40 backdrop-blur-sm px-2.5 py-1.5">
                  {regionLabel[sibling.data.region]}
                </span>
              </div>
              <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary/70">
                {sibling.data.nightsLabel ?? sibling.data.nights} nights · From ${sibling.data.pricePerGuestUSD.toLocaleString()}
              </p>
              <h3 class="font-display text-[1.5rem] leading-[1.1] tracking-[-0.015em] font-normal mt-2 group-hover:text-accent transition-colors" style="font-variation-settings: 'opsz' 36;">
                {sibling.data.name}
              </h3>
              {/* legacy bottom-overlay text — preserved below for graceful degradation but visually hidden */}
              <div class="hidden">
                <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-ink/80 mb-2">
                  {regionLabel[sibling.data.region]}
                </p>
                <h3 class="font-h3 text-ink text-[1.5rem] leading-[1.15] tracking-[-0.015em] font-medium" style="font-variation-settings: 'opsz' 36;">
                  {sibling.data.name} →
                </h3>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
