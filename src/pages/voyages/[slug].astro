---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import VoyageHero from '../../components/voyage/VoyageHero.astro';
import PricingCard from '../../components/voyage/PricingCard.astro';
import Timeline from '../../components/voyage/Timeline.astro';
import Gallery from '../../components/voyage/Gallery.astro';
import VoyageFaq from '../../components/voyage/VoyageFaq.astro';
import { Check, X } from 'lucide-react';

export async function getStaticPaths() {
  const voyages = await getCollection('voyages');
  return voyages.map((voyage) => ({
    params: { slug: voyage.data.slug },
    props: { voyage },
  }));
}

const { voyage } = Astro.props;
const { Content } = await render(voyage);

const regionLabel: Record<string, string> = {
  caribbean: 'Caribbean',
  bahamas: 'Bahamas',
  mediterranean: 'Mediterranean',
};

const fallbackGradients: Record<string, string> = {
  'british-virgin-islands': 'linear-gradient(165deg, #0E3F47 0%, #0A0A0A 70%, #1F1B17 100%)',
  bahamas: 'linear-gradient(165deg, #C92E1C 0%, #2A1F1A 60%, #0A0A0A 100%)',
  italy: 'linear-gradient(165deg, #1F1B17 0%, #0A0A0A 50%, #2A1F1A 100%)',
  greece: 'linear-gradient(165deg, #0E3F47 0%, #1F1B17 60%, #0A0A0A 100%)',
  croatia: 'linear-gradient(165deg, #161412 0%, #0E3F47 70%, #0A0A0A 100%)',
};

const emphasis: Record<string, string> = {
  'british-virgin-islands': 'Eight cabins, one catamaran, a week off the grid.',
  bahamas: 'Pink sand, shallow water, the slow Caribbean.',
  italy: 'Capri at sunrise, dinners that ruin you for hotels.',
  greece: 'The Cyclades at the pace they were meant to be sailed.',
  croatia: 'Split to Dubrovnik, the long way around.',
};

// Schema graph for the page — TouristTrip + Offer per available week +
// FAQPage from frontmatter FAQ + BreadcrumbList.
const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';
const pageUrl = `${baseUrl}/voyages/${voyage.data.slug}`;

const touristTrip = {
  '@type': 'TouristTrip',
  '@id': `${pageUrl}#trip`,
  name: voyage.data.name,
  description: voyage.data.seo.description,
  image: voyage.data.heroImage.startsWith('http')
    ? voyage.data.heroImage
    : `${baseUrl}${voyage.data.heroImage}`,
  touristType: ['Wellness traveler', 'Adventure traveler', 'Small-group traveler'],
  itinerary: voyage.data.itinerary.map((day) => ({
    '@type': 'Place',
    name: day.title,
    description: day.body,
  })),
  offers: voyage.data.availableWeeks.map((week) => ({
    '@type': 'Offer',
    price: voyage.data.pricePerGuestUSD,
    priceCurrency: 'USD',
    availability:
      week.cabinsAvailable > 0
        ? 'https://schema.org/InStock'
        : 'https://schema.org/SoldOut',
    validFrom: week.start,
    validThrough: week.end,
    inventoryLevel: { '@type': 'QuantitativeValue', value: week.cabinsAvailable },
  })),
  provider: {
    '@type': 'TravelAgency',
    name: 'Guiding Winds Unplug',
    url: baseUrl,
  },
};

const faqSchema = voyage.data.faq.length
  ? {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: voyage.data.faq.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: { '@type': 'Answer', text: item.a },
      })),
    }
  : null;

const breadcrumbs = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Voyages', item: `${baseUrl}/voyages` },
    { '@type': 'ListItem', position: 3, name: voyage.data.name, item: pageUrl },
  ],
};

const schemaGraph = [touristTrip, breadcrumbs];
if (faqSchema) schemaGraph.push(faqSchema);

// Cross-link to sibling voyages.
const allVoyages = await getCollection('voyages');
const siblings = allVoyages.filter((v) => v.data.slug !== voyage.data.slug).slice(0, 2);
---

<BaseLayout
  title={voyage.data.seo.title}
  description={voyage.data.seo.description}
  transparentNav
  schema={schemaGraph}
>
  <VoyageHero
    region={regionLabel[voyage.data.region]}
    name={voyage.data.name}
    heroEyebrow={voyage.data.heroEyebrow}
    heroImage={voyage.data.heroImage}
    heroImageAlt={voyage.data.heroImageAlt}
    emphasis={emphasis[voyage.data.slug] ?? 'Seven nights off the grid.'}
    pricePerGuestUSD={voyage.data.pricePerGuestUSD}
    nights={voyage.data.nights}
    anchorages={voyage.data.itinerary.length}
    fallbackGradient={fallbackGradients[voyage.data.slug] ?? '#161412'}
  />

  {/* Overview + sticky PricingCard */}
  <section class="bg-primary text-ink border-t border-hairline">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-24 sm:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-8">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-4">
            The voyage
          </p>
          <h2
            class="font-h2 text-ink leading-[1.05] tracking-[-0.02em] font-normal text-balance"
            style="font-size: clamp(1.875rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
          >
            {voyage.data.shortDescription}
          </h2>

          <div class="prose prose-invert mt-10 font-body-lg text-[1.0625rem] leading-[1.7] text-ink-soft max-w-prose">
            <Content />
          </div>

          {/* Inclusions / Exclusions split */}
          <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-10">
            <div>
              <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-ink-soft mb-5">
                In the price
              </p>
              <ul class="space-y-3">
                {
                  voyage.data.inclusions.map((item) => (
                    <li class="flex items-start gap-3 font-body-md text-[0.9375rem] text-ink-soft">
                      <Check className="size-4 text-accent shrink-0 mt-1" strokeWidth={2} />
                      {item}
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-ink-soft mb-5">
                Not included
              </p>
              <ul class="space-y-3">
                {
                  voyage.data.exclusions.map((item) => (
                    <li class="flex items-start gap-3 font-body-md text-[0.9375rem] text-ink-mute">
                      <X className="size-4 text-ink-mute shrink-0 mt-1" strokeWidth={2} />
                      {item}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>

        <div class="lg:col-span-4">
          <PricingCard
            pricePerGuestUSD={voyage.data.pricePerGuestUSD}
            availableWeeks={voyage.data.availableWeeks}
            voyageName={voyage.data.name}
            voyageSlug={voyage.data.slug}
          />
        </div>
      </div>
    </div>
  </section>

  <Timeline itinerary={voyage.data.itinerary} />
  <Gallery images={voyage.data.galleryImages} fallbackGradient={fallbackGradients[voyage.data.slug] ?? '#161412'} />
  {voyage.data.faq.length > 0 && <VoyageFaq faq={voyage.data.faq} />}

  {/* Cross-link siblings */}
  <section class="bg-primary text-ink border-t border-hairline">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-24">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-8">
        Or see another week
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {
          siblings.map((sibling) => (
            <a
              href={`/voyages/${sibling.data.slug}`}
              class="group relative block aspect-[3/2] overflow-hidden focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
              style={`background: ${fallbackGradients[sibling.data.slug] ?? '#161412'};`}
            >
              <div class="absolute inset-0 bg-gradient-to-t from-primary/85 via-primary/20 to-transparent transition-opacity duration-500 group-hover:opacity-60" aria-hidden="true" />
              <div class="absolute bottom-6 left-6 right-6">
                <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-ink/80 mb-2">
                  {regionLabel[sibling.data.region]}
                </p>
                <h3 class="font-h3 text-ink text-[1.5rem] leading-[1.15] tracking-[-0.015em] font-medium" style="font-variation-settings: 'opsz' 36;">
                  {sibling.data.name} →
                </h3>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
