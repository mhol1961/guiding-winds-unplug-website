---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/shared/PageHero.astro';

const title = '2027 Voyages · BVI, Bahamas, Italy, Greece, Croatia | Guiding Winds';
const description =
  'Fourteen weeks aboard a private catamaran across the British Virgin Islands, Bahamas, and Mediterranean. Pick a region, pick a week, hold a cabin for 72 hours.';

const voyages = await getCollection('voyages');

const allWeeks = voyages
  .flatMap((v) =>
    v.data.availableWeeks.map((w) => ({
      voyageSlug: v.data.slug,
      voyageName: v.data.name,
      region: v.data.region,
      price: v.data.pricePerGuestUSD,
      start: w.start,
      end: w.end,
      cabinsAvailable: w.cabinsAvailable,
    })),
  )
  .sort((a, b) => a.start.localeCompare(b.start));

const regionLabel: Record<string, string> = {
  caribbean: 'Caribbean',
  bahamas: 'Bahamas',
  mediterranean: 'Mediterranean',
};

const order: Record<string, number> = { caribbean: 0, bahamas: 1, mediterranean: 2 };
const sorted = voyages.sort((a, b) => order[a.data.region] - order[b.data.region]);

function formatWeek(start: string, end: string) {
  const s = new Date(`${start}T12:00:00Z`);
  const e = new Date(`${end}T12:00:00Z`);
  const fmt = (d: Date) =>
    d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
  return `${fmt(s)} – ${fmt(e)}, ${s.getUTCFullYear()}`;
}

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';
const schemaGraph = [
  {
    '@type': 'ItemList',
    name: '2027 Voyages — Guiding Winds Unplug',
    numberOfItems: voyages.length,
    itemListElement: voyages.map((v, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${baseUrl}/voyages/${v.data.slug}`,
      name: v.data.name,
    })),
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Voyages', item: `${baseUrl}/voyages` },
    ],
  },
];
---

<BaseLayout title={title} description={description} transparentNav schema={schemaGraph}>
  <PageHero
    eyebrow="Voyages · 2027"
    headlinePrefix="Three regions."
    headlineEmphasis="Fourteen weeks."
    headlineSuffix="One boat."
    subline="Caribbean January through March. Bahamas April and May. Mediterranean June through October. We sail every week ourselves — Clint at the helm, Dodie running the galley. Eight cabins, twelve guests, no crowds at anchor."
    heroImage="/img/stock/hero/hero-sunset-teak-deck-04.jpg"
    heroImageAlt="Sunset over a teak boat deck with the horizon line glowing gold"
  />

  {/* Voyage card grid — portrait 9:16, magazine-cover style */}
  <section class="bg-bone text-primary py-24 sm:py-32">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-5 lg:gap-6">
        {
          sorted.map((voyage) => {
            const weeks = voyage.data.availableWeeks.length;
            const totalCabins = voyage.data.availableWeeks.reduce(
              (sum, w) => sum + w.cabinsAvailable,
              0,
            );
            return (
              <a
                href={`/voyages/${voyage.data.slug}`}
                class="group flex flex-col focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
              >
                <div class="relative overflow-hidden aspect-[9/14] mb-5 bg-primary/5">
                  <img
                    src={voyage.data.heroImage}
                    alt={voyage.data.heroImageAlt}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.04]"
                  />
                  <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-primary/30 to-transparent pointer-events-none" aria-hidden="true"></div>
                  <span class="absolute top-4 left-4 font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold text-bone bg-primary/40 backdrop-blur-sm px-2.5 py-1.5">
                    {regionLabel[voyage.data.region]}
                  </span>
                  <span class="absolute bottom-4 right-4 font-label-caps uppercase tracking-[0.22em] text-[0.5625rem] font-semibold text-bone tabular-nums">
                    {totalCabins} cabins · {weeks} {weeks === 1 ? 'wk' : 'wks'}
                  </span>
                </div>
                <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary/55">
                  {voyage.data.nights} nights · {voyage.data.country}
                </p>
                <h2
                  class="font-display text-[1.375rem] leading-[1.1] tracking-[-0.015em] font-normal mt-2 group-hover:text-accent transition-colors text-balance"
                  style="font-variation-settings: 'opsz' 36, 'SOFT' 30, 'WONK' 0;"
                >
                  {voyage.data.name}
                </h2>
                <p class="font-body-md text-[0.9375rem] text-primary/65 mt-3 leading-[1.5]">
                  From ${voyage.data.pricePerGuestUSD.toLocaleString()} per guest
                </p>
                <span class="mt-4 inline-flex items-center gap-2 font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-accent group-hover:gap-3 transition-all">
                  Explore voyage
                  <svg viewBox="0 0 16 16" class="size-3" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  {/* Full 2027 calendar */}
  <section class="bg-bone text-primary py-24 border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-12">
        <h2
          class="font-display font-light leading-[1.05] tracking-[-0.025em]"
          style="font-size: clamp(1.875rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
        >
          The full 2027 calendar.
        </h2>
        <p class="font-body-md text-[1rem] text-primary/65">
          {allWeeks.length} weeks · {allWeeks.reduce((sum, w) => sum + w.cabinsAvailable, 0)} cabins available
        </p>
      </div>

      <div class="border-t border-rule">
        {
          allWeeks.map((week) => (
            <a
              href={`/voyages/${week.voyageSlug}`}
              class="group grid grid-cols-12 gap-4 items-baseline py-6 border-b border-rule hover:bg-bone-deep/30 transition-colors px-3 -mx-3 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
            >
              <div class="col-span-12 sm:col-span-3">
                <p class="font-label-caps uppercase tracking-[0.24em] text-[0.5625rem] font-semibold text-primary/55">
                  {regionLabel[week.region]}
                </p>
                <p class="font-display text-[1.125rem] text-primary mt-1 group-hover:text-accent transition-colors" style="font-variation-settings: 'opsz' 36;">
                  {week.voyageName}
                </p>
              </div>
              <p class="col-span-6 sm:col-span-4 font-body-md text-[1rem] text-primary/70 tabular-nums">
                {formatWeek(week.start, week.end)}
              </p>
              <p class="hidden sm:block sm:col-span-2 font-body-md text-[1rem] text-primary/70 tabular-nums">
                ${week.price.toLocaleString()}
              </p>
              <p class="col-span-6 sm:col-span-3 text-right font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold tabular-nums">
                <span
                  class:list={[
                    week.cabinsAvailable === 0
                      ? 'text-primary/40'
                      : week.cabinsAvailable <= 2
                        ? 'text-accent'
                        : 'text-primary/65',
                  ]}
                >
                  {week.cabinsAvailable === 0 ? 'Sold out' : `${week.cabinsAvailable} cabins`}
                </span>
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
