---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  UtensilsCrossed,
  Wine,
  Waves,
  BedDouble,
  Fuel,
  Anchor,
  Sunrise,
  WifiOff,
} from 'lucide-react';

const title = 'What is Aboard · All-Inclusive Catamaran Charter Inclusions | Guiding Winds Unplug';
const description =
  'Chef-prepared meals, premium open bar, snorkel gear, paddleboards, private cabins with ensuite heads, fuel and dockage. Everything is in. Bring a swimsuit.';

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';

const schemaGraph = [
  {
    '@type': 'Product',
    name: 'All-Inclusive Catamaran Voyage — Aboard',
    description,
    image: `${baseUrl}/img/source/hero/04-cockpit-sunrise.jpg`,
    brand: { '@type': 'Brand', name: 'Guiding Winds Unplug' },
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: 3550,
      highPrice: 3850,
      offerCount: 14,
    },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Aboard', item: `${baseUrl}/aboard` },
    ],
  },
];

const included = [
  { Icon: UtensilsCrossed, label: 'Chef-prepared meals', body: 'Breakfast, lunch, dinner. Dodie runs the galley. Cuisine shifts by destination — Caribbean breakfasts, Mediterranean dinners, a different theme most nights.' },
  { Icon: Wine, label: 'Premium open bar', body: 'Wine, spirits, beer, sparkling, mixers, coffee, the works. No upsell at sundown. Stocked to your preferences from the inquiry call.' },
  { Icon: Waves, label: 'Snorkel gear & SUPs', body: 'Masks, fins, snorkels in every size. Two paddleboards, two kayaks. A noodle for the people who just want a noodle.' },
  { Icon: BedDouble, label: 'Private cabin + head', body: 'Eight ensuite queens. Hatch over the bed. AC on shore power, fans underway. Linens and towels provided.' },
  { Icon: Fuel, label: 'Fuel & dockage', body: 'No itemized fuel surcharge. Dockage included at every overnight, including the mooring fees at the busier anchorages.' },
  { Icon: Anchor, label: 'Captain & host', body: 'Clint at the helm, USCG-licensed. Dodie running the boat. We sail every voyage personally — no rotating skippers.' },
  { Icon: Sunrise, label: 'Daily wellness', body: 'Optional morning breath sequence or yoga flow on the foredeck. Optional, not announced. Skip without comment.' },
  { Icon: WifiOff, label: 'The right to unplug', body: 'Starlink on by default. Off the moment you ask. Most guests have us flip it Wednesday and forget about it.' },
];

const boatAreas = [
  { label: 'The salon', body: 'Wraparound bench seating, a table that doubles for long dinners and chart sessions. Most of the week is lived here when you are not in the water.', img: '/img/stock/boat/boat-salon-01.jpg', alt: 'Wraparound salon seating on a sailing catamaran' },
  { label: 'The galley', body: 'Full-size induction cooktop, twin fridges, freezer for the long passages, a wine cooler. Dodie runs a tight kitchen — you should not feel obligated to help.', img: '/img/stock/boat/boat-galley-real.jpg', alt: 'White cabinetry galley on a yacht with sink, stainless beverage fridge, and espresso machine' },
  { label: 'The cabins', body: 'Eight queens, each with an ensuite head and a hatch over the bed. The Lagoon 50 has no "small cabin" — every cabin is the same generous footprint.', img: '/img/stock/boat/boat-cabin-03.jpg', alt: 'Queen cabin on a sailing catamaran with hatch above the bed' },
  { label: 'The foredeck', body: 'The trampoline is the social spot of the boat. Where the morning practice happens, where the afternoon naps happen, where the sundowner conversations happen.', img: '/img/source/boat/foredeck-bow-trampoline-sun-flare-01.jpg', alt: 'Foredeck trampoline of a catamaran in sun flare' },
];

const notIncluded = [
  'Flights to and from the embarkation port',
  'Travel insurance',
  'Crew gratuity (10–15% suggested)',
  'Off-boat dining and excursions you arrange independently',
];
---

<BaseLayout title={title} description={description} transparentNav schema={schemaGraph}>
  {/* Image hero with full-bleed real boat photo */}
  <section class="relative bg-primary text-ink overflow-hidden min-h-[80dvh] flex flex-col">
    <img
      src="/img/source/boat/cockpit-bench-seating-sunrise-01.jpg"
      alt="Cockpit bench seating on a sailing catamaran at sunrise"
      class="absolute inset-0 w-full h-full object-cover"
      fetchpriority="high"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-primary/30 via-transparent to-primary/95" aria-hidden="true"></div>
    <div class="relative z-10 min-h-[80dvh] flex flex-col">
      <div class="flex-1 flex items-end pb-16 lg:pb-24 px-7 lg:px-14 pt-32">
        <div class="max-w-[1400px] w-full mx-auto">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.75rem] font-semibold text-ink/90 mb-6">
            Aboard
          </p>
          <h1
            class="font-display text-ink font-light leading-[0.95] tracking-[-0.03em] max-w-5xl text-pretty"
            style="font-size: clamp(2.5rem, 6vw + 1rem, 5.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
          >
            Everything's in.
            <span class="block italic mt-2" style="font-variation-settings: 'opsz' 144, 'SOFT' 60, 'WONK' 1;">
              Bring a swimsuit.
            </span>
          </h1>
          <p class="font-body-lg text-[1.0625rem] lg:text-[1.1875rem] leading-[1.6] text-ink/85 mt-8 max-w-3xl">
            All-inclusive on this boat means what it says. One number covers
            your cabin, every meal, every drink, every piece of water gear,
            fuel, dockage, and the captain.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* 8-icon inclusion grid — hairline-divided, bone bg */}
  <section class="bg-bone text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="mb-16 max-w-3xl">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-5">
          In the price
        </p>
        <h2
          class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
          style="font-size: clamp(1.875rem, 3.5vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
        >
          Eight things you don't pay for again,
          <span class="italic" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
            once you're aboard.
          </span>
        </h2>
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 divide-y sm:divide-y-0 sm:divide-x divide-rule border-y border-rule">
        {
          included.map(({ Icon, label, body }) => (
            <li class="p-7 lg:p-8 flex flex-col">
              <Icon className="size-5 text-sun mb-5" strokeWidth={1.5} />
              <p class="font-label-caps uppercase tracking-[0.22em] text-[0.6875rem] font-semibold text-primary mb-3">
                {label}
              </p>
              <p class="font-body-md text-[0.9375rem] leading-[1.6] text-primary/70 text-balance">{body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* The boat — 4 image-led sections, alternating left/right */}
  <section class="bg-bone text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="mb-16 max-w-3xl">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-5">
          The boat
        </p>
        <h2
          class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
          style="font-size: clamp(1.875rem, 3.5vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
        >
          A Lagoon 50.
          <span class="italic" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
            Chosen for cabin volume, not the spec sheet.
          </span>
        </h2>
      </div>
      <div class="space-y-20 lg:space-y-32">
        {
          boatAreas.map((area, i) => (
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
              <div class={`lg:col-span-7 ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
                <figure class="relative aspect-[17/10] overflow-hidden bg-primary/5">
                  <img src={area.img} alt={area.alt} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover" />
                </figure>
              </div>
              <div class={`lg:col-span-5 ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
                <p class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-sun-deep mb-4">
                  Plate 0{i + 1} · {area.label}
                </p>
                <h3
                  class="font-display text-[1.75rem] leading-[1.15] tracking-[-0.015em] font-normal mb-4"
                  style="font-variation-settings: 'opsz' 36;"
                >
                  {area.label}
                </h3>
                <p class="font-body-lg text-[1.0625rem] leading-[1.7] text-primary/75 text-balance">
                  {area.body}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* What's NOT included — numbered list on bone-deep accent panel */}
  <section class="bg-bone-deep/30 text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-5">
            Not in the price
          </p>
          <h2
            class="font-display font-light leading-[1.05] tracking-[-0.025em] text-balance"
            style="font-size: clamp(1.625rem, 3vw + 1rem, 2.25rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
          >
            Four things
            <span class="italic block" style="font-variation-settings: 'opsz' 72, 'SOFT' 60, 'WONK' 1;">
              you cover yourself.
            </span>
          </h2>
        </div>
        <div class="lg:col-span-8">
          <ol class="space-y-6 font-body-lg text-[1.0625rem] leading-[1.65] text-primary/80">
            {
              notIncluded.map((item, i) => (
                <li class="flex gap-6 pb-6 border-b border-rule last:border-0">
                  <span class="font-display text-[1.75rem] text-sun-deep shrink-0 leading-none mt-1 tabular-nums" style="font-variation-settings: 'opsz' 36;">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <p>{item}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </section>

  {/* Typical day */}
  <section class="bg-bone text-primary py-24 sm:py-32 border-t border-rule">
    <div class="max-w-[820px] mx-auto px-7 lg:px-0">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/55 mb-5 text-center">
        A typical day
      </p>
      <h2
        class="font-display font-light leading-[1.05] tracking-[-0.025em] mb-12 text-balance text-center"
        style="font-size: clamp(1.875rem, 3.5vw + 1rem, 2.75rem); font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;"
      >
        Sunrise to sundown,
        <span class="italic block" style="font-variation-settings: 'opsz' 96, 'SOFT' 60, 'WONK' 1;">
          what it actually looks like.
        </span>
      </h2>
      <div class="space-y-6 font-body-lg text-[1.0625rem] lg:text-[1.125rem] leading-[1.75] text-primary/75 text-balance">
        <p>
          Coffee on deck at first light for whoever's up. Optional morning
          breath sequence or yoga flow on the foredeck around seven, twenty
          minutes, no announcement. Breakfast at eight — eggs, fruit, fresh
          bread from whatever village we were in yesterday. Dive in off the
          swim platform whenever.
        </p>
        <p>
          By ten we've usually pulled the anchor for a short, easy passage
          to the next stop. Most legs are under two hours. You can sit at
          the helm with Clint, lie on the trampoline, read in the salon —
          the day is yours. Lunch on the boat at one — light, mostly off
          the grill, always with a cold something.
        </p>
        <p>
          Afternoon is the long open block. Snorkel, paddle, kayak, nap,
          read, walk ashore if we're tied up. By five we're on a sundowner.
          By seven Dodie's brought dinner up — long meal, long stars, no
          schedule for tomorrow until tomorrow.
        </p>
      </div>
      <div class="mt-14 text-center">
        <a
          href="/calendar"
          class="group inline-flex items-center gap-3 font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold text-primary border-b-2 border-accent pb-1 hover:text-accent transition-colors"
        >
          See Available Weeks
          <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
