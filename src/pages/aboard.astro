---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  UtensilsCrossed,
  Wine,
  Waves,
  BedDouble,
  Fuel,
  Anchor,
  Sunrise,
  WifiOff,
} from 'lucide-react';

const title = 'What is Aboard · All-Inclusive Catamaran Charter Inclusions | Guiding Winds Unplug';
const description =
  'Chef-prepared meals, premium open bar, snorkel gear, paddleboards, private cabins with ensuite heads, fuel and dockage. Everything is in. Bring a swimsuit.';

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';

const schemaGraph = [
  {
    '@type': 'Product',
    name: 'All-Inclusive Catamaran Voyage — Aboard',
    description,
    image: `${baseUrl}/og/aboard.png`,
    brand: { '@type': 'Brand', name: 'Guiding Winds Unplug' },
    offers: {
      '@type': 'AggregateOffer',
      priceCurrency: 'USD',
      lowPrice: 3550,
      highPrice: 3850,
      offerCount: 14,
    },
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Aboard', item: `${baseUrl}/aboard` },
    ],
  },
];

const included = [
  {
    Icon: UtensilsCrossed,
    label: 'Chef-Prepared Meals',
    body: 'Breakfast, lunch, dinner. Dodie runs the galley. Cuisine shifts by destination — Caribbean breakfasts, Mediterranean dinners, a different theme most nights.',
  },
  {
    Icon: Wine,
    label: 'Premium Open Bar',
    body: 'Wine, spirits, beer, sparkling, mixers, coffee, the works. No upsell at sundown. Stocked to your preferences from the inquiry call.',
  },
  {
    Icon: Waves,
    label: 'Snorkel Gear & SUPs',
    body: 'Masks, fins, snorkels in every size. Two paddleboards, two kayaks. A noodle for the people who just want a noodle.',
  },
  {
    Icon: BedDouble,
    label: 'Private Cabin + Head',
    body: 'Eight ensuite queens. Hatch over the bed. AC on shore power, fans underway. Linens and towels provided.',
  },
  {
    Icon: Fuel,
    label: 'Fuel & Dockage',
    body: 'No itemized fuel surcharge. Dockage included at every overnight, including the mooring fees at the busier anchorages.',
  },
  {
    Icon: Anchor,
    label: 'Captain & Crew',
    body: 'Clint at the helm, USCG-licensed. Dodie running the boat. We sail every voyage personally — no rotating skippers.',
  },
  {
    Icon: Sunrise,
    label: 'Daily Wellness',
    body: 'Optional morning breath sequence or yoga flow on the foredeck. Optional, not announced. Skip without comment.',
  },
  {
    Icon: WifiOff,
    label: 'The Right to Unplug',
    body: 'Starlink on by default. Off the moment you ask. Most guests have us flip it Wednesday and forget about it.',
  },
];

const notIncluded = [
  'Flights to and from the embarkation port',
  'Travel insurance',
  'Crew gratuity (10–15% suggested)',
  'Off-boat dining and excursions you arrange independently',
];
---

<BaseLayout title={title} description={description} schema={schemaGraph}>
  {/* Hero */}
  <section class="bg-primary text-ink border-b border-hairline">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 pt-20 pb-20 lg:pt-28 lg:pb-28">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-6">
        Aboard
      </p>
      <h1
        class="font-display text-ink leading-[0.95] tracking-[-0.03em] font-light text-balance max-w-4xl"
        style="font-size: clamp(2.5rem, 6vw + 1rem, 5.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
      >
        Everything's in.
        <span
          class="italic"
          style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 1;"
        >
          Bring a swimsuit.
        </span>
      </h1>
      <p class="font-body-lg text-[1.0625rem] leading-[1.65] text-ink-soft mt-8 max-w-3xl">
        All-inclusive on this boat means what it says. One number on the invoice
        covers your cabin, every meal, every drink, every piece of water gear,
        fuel, dockage, and the captain. The only on-trip costs are the things
        you choose — a shore dinner you want, a tip at the end, the flights you
        booked yourself.
      </p>
    </div>
  </section>

  {/* 8-icon inclusion grid */}
  <section class="bg-primary text-ink border-t border-hairline">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-24 sm:py-32">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-14">
        {
          included.map(({ Icon, label, body }) => (
            <div class="flex flex-col">
              <Icon className="size-7 text-accent mb-5" strokeWidth={1.25} />
              <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-ink mb-2">
                {label}
              </p>
              <p class="font-body-md text-[0.9375rem] leading-[1.55] text-ink-soft">{body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* The boat */}
  <section class="bg-primary text-ink border-t border-hairline">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-24 sm:py-32">
      <div class="max-w-2xl mb-16">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-4">
          The boat
        </p>
        <h2
          class="font-h2 text-ink leading-[1.05] tracking-[-0.02em] font-normal text-balance"
          style="font-size: clamp(1.875rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
        >
          A Lagoon 50. Chosen for cabin volume.
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-y-16 gap-x-12">
        {
          [
            {
              label: 'The salon',
              body: 'Wraparound bench seating, a table that doubles for long dinners and chart sessions. Most of the week is lived here when you are not in the water.',
            },
            {
              label: 'The galley',
              body: 'Full-size induction cooktop, twin fridges, freezer for the long passages, a wine cooler. Dodie runs a tight kitchen — you should not feel obligated to help.',
            },
            {
              label: 'The cabins',
              body: 'Eight queens, each with an ensuite head and a hatch over the bed. The Lagoon 50 has no "small cabin" — every cabin is the same generous footprint.',
            },
            {
              label: 'The foredeck',
              body: 'The trampoline is the social spot of the boat. Where the morning practice happens, where the afternoon naps happen, where the sundowner conversations happen.',
            },
            {
              label: "The captain's helm",
              body: 'Forward-facing helm with full instruments, Starlink, two chartplotters. Clint sails the boat. You are welcome to sit beside him for a passage if you want to learn.',
            },
            {
              label: 'The heads',
              body: 'One per cabin. Marine toilet, separate shower stall, ventilation. Hot water on demand. Saltwater rinse on the swim platform for after the swim.',
            },
          ].map((area) => (
            <article>
              <p class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-accent mb-3">
                {area.label}
              </p>
              <p class="font-body-lg text-[1.0625rem] leading-[1.7] text-ink-soft max-w-prose">{area.body}</p>
            </article>
          ))
        }
      </div>

      <p class="font-body-sm text-[0.8125rem] text-ink-mute mt-14 max-w-prose">
        Photography of the boat interior is being added through Q1 2027. The
        salon looks better than it photographs.
      </p>
    </div>
  </section>

  {/* What's not included */}
  <section class="bg-bone text-primary border-t border-primary/10">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-24 sm:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <div class="lg:col-span-4">
          <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-primary/55 mb-4">
            Not in the price
          </p>
          <h2
            class="font-h2 text-primary leading-[1.05] tracking-[-0.02em] font-normal text-balance"
            style="font-size: clamp(1.875rem, 3vw + 1rem, 2.25rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
          >
            Four things you cover yourself.
          </h2>
        </div>
        <div class="lg:col-span-8">
          <ol class="space-y-6 font-body-lg text-[1.0625rem] leading-[1.65] text-primary/80">
            {
              notIncluded.map((item, i) => (
                <li class="flex gap-6 pb-6 border-b border-primary/10 last:border-0">
                  <span class="font-h3 text-[1.5rem] text-accent shrink-0 leading-none mt-1 tabular-nums">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <p>{item}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </div>
    </div>
  </section>

  {/* A typical day aboard */}
  <section class="bg-primary text-ink border-t border-hairline">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-24 sm:py-32">
      <div class="max-w-3xl">
        <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-6">
          A typical day
        </p>
        <h2
          class="font-h2 text-ink leading-[1.05] tracking-[-0.02em] font-normal text-balance mb-10"
          style="font-size: clamp(1.875rem, 3vw + 1rem, 2.5rem); font-variation-settings: 'opsz' 72, 'SOFT' 30, 'WONK' 0;"
        >
          Sunrise to sundown, what it actually looks like.
        </h2>
        <div class="space-y-6 font-body-lg text-[1.0625rem] leading-[1.7] text-ink-soft">
          <p>
            Coffee on deck at first light for whoever's up. Optional morning
            breath sequence or yoga flow on the foredeck around seven, twenty
            minutes, no announcement. Breakfast at eight — eggs, fruit, fresh
            bread from whatever village we were in yesterday. Dive in off the
            swim platform whenever.
          </p>
          <p>
            By ten we've usually pulled the anchor for a short, easy passage
            to the next stop. Most legs are under two hours. You can sit at
            the helm with Clint, lie on the trampoline, read in the salon —
            the day is yours. Lunch on the boat at one — light, mostly off
            the grill, always with a cold something.
          </p>
          <p>
            Afternoon is the long open block. Snorkel, paddle, kayak, nap,
            read, walk ashore if we're tied up. By five we're on a sundowner.
            By seven Dodie's brought dinner up — long meal, long stars, no
            schedule for tomorrow until tomorrow.
          </p>
        </div>

        <div class="mt-14">
          <a
            href="/calendar"
            class="inline-flex items-center justify-center cursor-pointer bg-accent text-ink font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold px-8 py-[18px] hover:bg-accent-hot transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
          >
            See Available Weeks
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
