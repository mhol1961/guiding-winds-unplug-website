---
import BaseLayout from '../layouts/BaseLayout.astro';
import InquiryForm from '../components/shared/InquiryForm.astro';
import PageHero from '../components/shared/PageHero.astro';
import { Mail, Clock } from 'lucide-react';

const title = 'Book a Quick Zoom Call | Guiding Winds Unplug';
const description =
  'We speak with every guest before booking. Tell us which week and book a quick call. Dodie or Clint reply within 24 hours.';

const voyageSlug = new URL(Astro.url).searchParams.get('voyage') ?? undefined;
const regionFromSlug: Record<string, 'bvi' | 'bahamas' | 'mediterranean'> = {
  'british-virgin-islands': 'bvi',
  bahamas: 'bahamas',
  italy: 'mediterranean',
  greece: 'mediterranean',
  croatia: 'mediterranean',
};
const region = voyageSlug ? regionFromSlug[voyageSlug] : undefined;

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';
const schemaGraph = [
  { '@type': 'ContactPage', name: 'Inquire - Guiding Winds Unplug', description },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Inquire', item: `${baseUrl}/inquire` },
    ],
  },
];
---

<BaseLayout title={title} description={description} schema={schemaGraph} hideFloatingCta transparentNav>
  <PageHero
    compact
    eyebrow="Book a quick Zoom call"
    headlinePrefix="Tell us which week, and"
    headlineEmphasis="let's book a quick call."
    subline="We speak with every guest before booking. Send the form or book a quick call, and Dodie or Clint will reply within 24 hours with availability and the next step."
    heroImage="/img/stock/hero/hero-bvi-catamaran-turquoise-01.jpg"
    heroImageAlt="Aerial view of a small green island ringed by turquoise reef water in the British Virgin Islands"
  />

  {/* Form + side panel */}
  <section class="bg-bone text-primary py-16 lg:py-24">
    <div class="max-w-[1400px] mx-auto px-7 lg:px-14">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-20">
        <div class="lg:col-span-7">
          <InquiryForm region={region} voyageSlug={voyageSlug} />
        </div>

        <aside class="lg:col-span-5 space-y-12">
          <div class="border border-rule p-6">
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-4">
              Prefer to talk now
            </p>
            <a
              href="tel:+17723103777"
              class="group inline-flex items-center justify-center gap-3 w-full cursor-pointer bg-primary text-bone font-label-caps uppercase tracking-[0.22em] text-[0.75rem] font-semibold px-6 py-[16px] hover:bg-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-3"
            >
              Book a quick call
              <svg viewBox="0 0 16 16" class="size-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <p class="font-body-sm text-[0.8125rem] text-primary/65 mt-3 text-center">
              (772) 310-3777 · we speak with every guest before booking
            </p>
          </div>

          <div>
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-6">
              What happens next
            </p>
            <ol class="space-y-7">
              {
                [
                  { title: 'You send the inquiry', body: 'Takes 60 seconds. Tell us your preferred week, or "flexible - recommend one."' },
                  { title: 'We reply within 24 hours', body: 'Email or text, your choice. We confirm cabin availability and set up a quick call.' },
                  { title: 'We talk it through', body: 'We speak with every guest before booking. On a quick call we answer your questions and, once you decide, send the private booking link.' },
                ].map((step, i) => (
                  <li class="flex gap-5 pb-7 border-b border-rule last:border-0">
                    <span class="font-display text-[1.75rem] text-sun-deep shrink-0 leading-none tabular-nums" style="font-variation-settings: 'opsz' 36;">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <div>
                      <p class="font-display text-[1.25rem] leading-[1.2] font-normal" style="font-variation-settings: 'opsz' 36;">
                        {step.title}
                      </p>
                      <p class="font-body-md text-[1rem] leading-[1.6] text-primary/65 mt-2">{step.body}</p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </div>

          <div class="border border-rule p-6">
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-4">
              Prefer to skip the form
            </p>
            <a
              href="mailto:dodie@guidingwinds-unplug.com"
              class="flex items-center gap-3 font-body-md text-[1rem] text-primary hover:text-accent transition-colors py-2"
            >
              <Mail className="size-4 text-sun" strokeWidth={1.5} />
              dodie@guidingwinds-unplug.com
            </a>
            <div class="flex items-center gap-3 font-body-md text-[0.9375rem] text-primary/65 py-2">
              <Clock className="size-4 text-sun" strokeWidth={1.5} />
              Replies M-F, usually within 4h
            </div>
          </div>

          <div class="border border-rule p-6">
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-4">
              Travelers insurance
            </p>
            <p class="font-body-md text-[0.9375rem] leading-[1.6] text-primary/75 mb-3">
              We recommend a policy that lets you cancel for any reason and get a full refund.
            </p>
            <a
              href="https://trawickinternational.com/?agent=21057"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary border-b border-accent pb-1 hover:text-accent transition-colors"
            >
              Get an insurance quote
              <svg viewBox="0 0 16 16" class="size-3" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>

          <div>
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-primary/70 mb-6">
              Three most common
            </p>
            <dl class="space-y-7">
              {
                [
                  { q: 'Cancellation?', a: 'We recommend travelers insurance that lets you cancel for any reason and get a full refund: trawickinternational.com/?agent=21057.' },
                  { q: 'How do we book?', a: 'We speak with every guest before booking. After a quick call we send you a private booking link.' },
                  { q: 'Kids welcome?', a: 'Yes, especially on whole-boat charters. The boat sleeps 12 comfortably; this is an adult-pace trip.' },
                ].map((item) => (
                  <div>
                    <dt class="font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-sun-deep mb-2">
                      {item.q}
                    </dt>
                    <dd class="font-body-md text-[0.9375rem] leading-[1.6] text-primary/75">{item.a}</dd>
                  </div>
                ))
              }
            </dl>
            <a href="/faq" class="inline-flex items-center gap-2 mt-7 font-label-caps uppercase tracking-[0.22em] text-[0.625rem] font-semibold text-primary border-b border-accent pb-1 hover:text-accent transition-colors">
              See the full FAQ
              <svg viewBox="0 0 16 16" class="size-3" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M1 8h13M9 3l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
