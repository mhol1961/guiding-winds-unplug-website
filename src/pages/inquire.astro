---
import BaseLayout from '../layouts/BaseLayout.astro';
import InquiryForm from '../components/shared/InquiryForm.astro';
import { Mail, Clock } from 'lucide-react';

const title = 'Inquire · Hold a Cabin for 72 Hours | Guiding Winds Unplug';
const description =
  'Tell us which week and we will hold a cabin for 72 hours. No payment required. Dodie or Clint reply within 24 hours.';

// Voyage deep-link via ?voyage=slug — used by the PricingCard button.
const voyageSlug = new URL(Astro.url).searchParams.get('voyage') ?? undefined;
const regionFromSlug: Record<string, 'bvi' | 'bahamas' | 'mediterranean'> = {
  'british-virgin-islands': 'bvi',
  bahamas: 'bahamas',
  italy: 'mediterranean',
  greece: 'mediterranean',
  croatia: 'mediterranean',
};
const region = voyageSlug ? regionFromSlug[voyageSlug] : undefined;

const baseUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://guidingwinds-unplug.com';
const schemaGraph = [
  {
    '@type': 'ContactPage',
    name: 'Inquire — Guiding Winds Unplug',
    description,
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Inquire', item: `${baseUrl}/inquire` },
    ],
  },
];
---

<BaseLayout title={title} description={description} schema={schemaGraph}>
  {/* Hero */}
  <section class="bg-primary text-ink border-b border-hairline">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 pt-20 pb-12 lg:pt-28 lg:pb-16">
      <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-6">
        Inquire
      </p>
      <h1
        class="font-display text-ink leading-[0.95] tracking-[-0.03em] font-light text-balance max-w-4xl"
        style="font-size: clamp(2.25rem, 5vw + 1rem, 4.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
      >
        Tell us which week. We'll hold a cabin for
        <span class="italic" style="font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 1;">seventy-two hours.</span>
      </h1>
      <p class="font-body-lg text-[1.0625rem] leading-[1.65] text-ink-soft mt-8 max-w-3xl">
        No payment required. Dodie or Clint will reply within 24 hours with
        availability and the next step.
      </p>
    </div>
  </section>

  {/* Form + side panel */}
  <section class="bg-primary text-ink">
    <div class="max-w-[1320px] mx-auto px-7 lg:px-14 py-16 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7">
          <InquiryForm region={region} voyageSlug={voyageSlug} />
        </div>

        <aside class="lg:col-span-5 space-y-10">
          {/* What happens next */}
          <div>
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-6">
              What happens next
            </p>
            <ol class="space-y-6">
              {
                [
                  {
                    title: 'You send the inquiry',
                    body: 'Takes 60 seconds. Tell us your preferred week, or "flexible — recommend one."',
                  },
                  {
                    title: 'We reply within 24 hours',
                    body: 'Email or text, your choice. We confirm cabin availability and answer the first batch of questions.',
                  },
                  {
                    title: 'We hold a cabin for 72 hours',
                    body: 'No deposit required to hold. Once you confirm, a 25% deposit locks the cabin; balance due 60 days before departure.',
                  },
                ].map((step, i) => (
                  <li class="flex gap-5 pb-6 border-b border-hairline last:border-0">
                    <span class="font-h3 text-[1.5rem] text-accent shrink-0 leading-none tabular-nums">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <div>
                      <p class="font-h3 text-ink text-[1.125rem] leading-[1.2] font-medium" style="font-variation-settings: 'opsz' 36;">
                        {step.title}
                      </p>
                      <p class="font-body-md text-[0.9375rem] leading-[1.55] text-ink-soft mt-2">{step.body}</p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </div>

          {/* Contact card */}
          <div class="border border-hairline p-6">
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-4">
              Prefer to skip the form
            </p>
            <a
              href="mailto:dodie@guidingwinds-unplug.com"
              class="flex items-center gap-3 font-body-md text-[0.9375rem] text-ink hover:text-accent transition-colors py-2"
            >
              <Mail className="size-4 text-accent" strokeWidth={1.5} />
              dodie@guidingwinds-unplug.com
            </a>
            <div class="flex items-center gap-3 font-body-md text-[0.9375rem] text-ink-soft py-2">
              <Clock className="size-4 text-accent" strokeWidth={1.5} />
              Replies M–F, usually within 4h
            </div>
          </div>

          {/* Mini-FAQ */}
          <div>
            <p class="font-label-caps uppercase tracking-[0.28em] text-[0.6875rem] font-semibold text-ink-soft mb-6">
              Three most common
            </p>
            <dl class="space-y-6">
              {
                [
                  {
                    q: 'Cancellation?',
                    a: '90+ days full refund, 90–45 days 50%, under 45 we rebook you for any future week with availability.',
                  },
                  {
                    q: 'Payment options?',
                    a: 'Stripe (card), wire transfer, or check. 25% deposit to lock, balance 60 days out.',
                  },
                  {
                    q: 'Kids welcome?',
                    a: 'Yes, especially on whole-boat charters. The boat sleeps 12 comfortably; this is an adult-pace trip.',
                  },
                ].map((item) => (
                  <div>
                    <dt class="font-label-caps uppercase tracking-[0.24em] text-[0.625rem] font-semibold text-accent mb-2">
                      {item.q}
                    </dt>
                    <dd class="font-body-md text-[0.9375rem] leading-[1.55] text-ink-soft">{item.a}</dd>
                  </div>
                ))
              }
            </dl>
            <a
              href="/faq"
              class="inline-flex items-center gap-2 mt-6 font-label-caps uppercase tracking-[0.28em] text-[0.625rem] font-semibold text-accent hover:text-accent-hot transition-colors"
            >
              See the full FAQ →
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
