# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.local
.env.production
.env.*.local

# cloudflare adapter / wrangler
.wrangler/
.dev.vars

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Review screenshots — any PNG/JPG dropped at the public/ root is
# almost always a review capture (full-page screenshots, debug
# annotations, reference images). Real production assets live in
# public/img/, public/media/, public/og/ — those stay tracked.
public/*.png
public/*.jpg
public/*.jpeg
!public/img/
!public/media/
!public/og/

# THIS REPO IS PUBLIC. Keep internal/sensitive material out of it.
# (gitignore has no inline comments — keep each note on its own line)
# internal GHL ops notes (account config, strategy)
ops/
# client proposals / pricing
docs/*.pdf
# personal text-message screenshots
public/img/dodie-text-*.png

