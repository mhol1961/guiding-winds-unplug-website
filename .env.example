# ============================================================
# Guiding Winds Unplug — environment template
# ============================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — NEVER commit secrets to the repo.
# See SETUP.md for where to find each value.
# See GHL-INTEGRATION.md for the GHL credential setup walkthrough.
# ============================================================

# ─── GoHighLevel (Dodie's subaccount) ─────────────────────────
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# Found in: GHL → Settings → Business Info → Location ID
GHL_LOCATION_ID=

# Found in: GHL → Settings → Private Integrations → Create New Integration
# Required scopes: contacts.write, contacts.readonly, calendars.write,
#                  calendars.readonly, workflows.readonly, tags.write
GHL_PRIVATE_TOKEN=

# Found in: GHL → Calendars → [calendar name] → Settings → Calendar ID
GHL_CALENDAR_ID_BVI=
GHL_CALENDAR_ID_BAHAMAS=
GHL_CALENDAR_ID_MED=

# ─── Analytics ─────────────────────────────────────────────────
# Plausible domain — set to the public site domain
PLAUSIBLE_DOMAIN=guidingwinds-unplug.com

# ─── Public (these are exposed to the client; PUBLIC_ prefix required) ─
PUBLIC_SITE_URL=https://guidingwinds-unplug.com
PUBLIC_BUSINESS_NAME=Guiding Winds Unplug
PUBLIC_CONTACT_EMAIL=dodie@guidingwinds-unplug.com

# ─── Build / runtime ───────────────────────────────────────────
# Pinned for Cloudflare Pages — also pinned via package.json engines (>=22.12.0)
NODE_VERSION=22

# ─── Optional: development overrides ───────────────────────────
# Set to "true" to disable rate limiting in dev for easier testing
# DISABLE_RATE_LIMIT=false

# Set to "true" to bypass the GHL API entirely and log payloads instead
# (useful when GHL credentials aren't available)
# DRY_RUN_GHL=false
